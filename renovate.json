{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "helpers:pinGitHubActionDigests"
  ],
  "baseBranchPatterns": [
    "main"
  ],
  "npm": {
    "enabled": true,
    "automerge": false,
    "rangeStrategy": "bump",
    "major": {
      "enabled": false
    },
    "packageRules": [
      {
        "minimumReleaseAge": "2 days",
        "matchUpdateTypes": [
          "minor",
          "patch"
        ],
        "groupName": "NPM Minor and Patch Updates"
      }
    ]
  },
  "github-actions": {
    "enabled": true,
    "automerge": false,
    "packageRules": [
      {
        "matchManagers": [
          "github-actions"
        ],
        "groupName": "GitHub Actions Updates"
      }
    ]
  },
  "packageRules": [
    {
      "matchCategories": [
        "docker"
      ],
      "enabled": true,
      "automerge": false,
      "pinDigests": false,
      "groupName": "Docker Compose Updates",
      "matchPackageNames": [
        "/.*/"
      ],
      "matchManagers": [
        "docker-compose",
        "docker"
      ]
    }
  ]
}