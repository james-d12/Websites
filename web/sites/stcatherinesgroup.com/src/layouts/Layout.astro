---
import '../styles/global.css'

export interface Props {
  title?: string;
  description?: string;
}

const { title = "St Catherine's Group", description = "Exceptional healthcare services, personally delivered." } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<title>{title}</title>
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<link rel="sitemap" href="/sitemap-index.xml"/>
		<link rel="canonical" href="https://stcatherinesgrouo.com/">
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Lora:wght@400;500;600;700&display=swap" rel="stylesheet" />
		<meta name="generator" content={Astro.generator} />
	</head>
	<body class="bg-warm-50 text-gray-700 antialiased">
		<slot />
	</body>
</html>
