---
import {Image} from "astro:assets";
import heroImage from "../assets/national-cancer-institute-BxXgTQEw1M4-unsplash.jpg";
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <!-- Background image -->
    <div class="absolute inset-0">
        <Image
                src={heroImage}
                alt="Compassionate healthcare"
                class="w-full h-full object-cover"
        />
    </div>

    <!-- Dark overlay for text readability
    <div class="absolute inset-0 bg-linear-to-br from-green-dark/80 via-green-dark/70 to-green-dark/60"></div>
    -->

    <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
        <p class="text-green-100 text-sm md:text-base font-medium tracking-[0.2em] uppercase mb-6">
            Compassionate Healthcare
        </p>

        <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold text-white leading-tight mb-6">
            Exceptional Care,<br/>
            <span class="text-green-100">Personally Delivered</span>
        </h1>

        <p class="text-lg md:text-xl text-white/80 max-w-2xl mx-auto mb-10 leading-relaxed font-light">
            Dedicated to providing outstanding one-to-one healthcare services
            with the warmth and attention you deserve.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a
                    href="/services"
                    class="inline-flex items-center justify-center px-8 py-3.5 bg-green-dark text-white font-medium rounded-lg transition-all duration-200 text-sm tracking-wide uppercase"
            >
                Our Services
            </a>
            <a
                    href="/contact"
                    class="inline-flex items-center justify-center px-8 py-3.5 bg-white text-green-dark font-medium rounded-lg transition-all duration-200 text-sm tracking-wide uppercase"
            >
                Get in Touch
            </a>
        </div>
    </div>
</section>
