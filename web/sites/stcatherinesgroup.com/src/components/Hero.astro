---
import {Image} from "astro:assets";
import heroImage from "../assets/centre-for-ageing-better-lNTbuoYMSro-unsplash.jpg";
---

<section class="relative min-h-screen bg-white flex items-center py-12 sm:py-16 lg:py-20">
    <div class="max-w-[1600px] 2xl:max-w-[1800px] mx-auto px-4 sm:px-6 lg:px-8 xl:px-16 2xl:px-24 w-full">
        <div class="grid lg:grid-cols-5 gap-8 sm:gap-10 lg:gap-16 xl:gap-20 items-center">

            <!-- Text -->
            <div class="space-y-6 sm:space-y-8 lg:col-span-2 order-2 lg:order-1">
                <div>
                    <p class="text-green-dark uppercase tracking-[0.2em] text-xs sm:text-sm font-medium mb-4 sm:mb-6">
                        Compassionate Healthcare
                    </p>

                    <h1 class="text-3xl sm:text-4xl lg:text-5xl xl:text-6xl font-bold text-gray-900 leading-tight mb-4 sm:mb-6">
                        Exceptional Care,<br/>
                        <span class="text-green-dark">Personally Delivered</span>
                    </h1>

                    <p class="text-base sm:text-lg lg:text-xl text-gray-600 leading-relaxed">
                        Dedicated to providing outstanding one-to-one healthcare services
                        with the warmth and attention you deserve.
                    </p>
                </div>

                <a
                    href="#services"
                    class="inline-flex items-center gap-2 sm:gap-3 px-6 sm:px-8 py-4 sm:py-5 bg-green-dark text-white font-semibold text-lg sm:text-xl rounded-lg hover:bg-green-dark/90 transition-all duration-200 group shadow-lg"
                >
                    <span>Explore Our Services</span>
                    <svg class="w-5 h-5 sm:w-6 sm:h-6 group-hover:translate-y-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
                    </svg>
                </a>

                <!-- Trust indicators -->
                <div class="grid grid-cols-3 gap-4 sm:gap-6 lg:gap-8 pt-6 sm:pt-8 border-t border-gray-200">
                    <div>
                        <p class="text-2xl sm:text-3xl lg:text-4xl font-bold text-green-dark mb-1">25+</p>
                        <p class="text-xs sm:text-sm text-gray-600">Years Experience</p>
                    </div>

                    <div>
                        <p class="text-2xl sm:text-3xl lg:text-4xl font-bold text-green-dark mb-1">5k+</p>
                        <p class="text-xs sm:text-sm text-gray-600">Patients Supported</p>
                    </div>

                    <div>
                        <p class="text-2xl sm:text-3xl lg:text-4xl font-bold text-green-dark mb-1">24/7</p>
                        <p class="text-xs sm:text-sm text-gray-600">Care Available</p>
                    </div>
                </div>
            </div>

            <!-- Image -->
            <div class="relative h-[350px] sm:h-[450px] md:h-[550px] lg:h-[600px] xl:h-[700px] lg:col-span-3 order-1 lg:order-2">
                <div class="absolute inset-0 bg-green-dark/10 rounded-2xl transform rotate-3"></div>
                <Image
                    src={heroImage}
                    alt="Healthcare support"
                    class="relative rounded-2xl object-cover w-full h-full shadow-2xl"
                />
            </div>

        </div>
    </div>
</section>

