---
interface Testimonial {
    quote: string;
    name: string;
    relationship: string;
    service: string;
}

interface Props {
    testimonials: Testimonial[];
}

const {testimonials} = Astro.props;
---

<section class="py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-3xl mx-auto text-center mb-16">
            <p class="text-green-dark text-sm font-medium tracking-[0.2em] uppercase mb-4">Testimonials</p>
            <h2 class="text-5xl md:text-6xl lg:text-7xl font-bold mb-6">
                What People Say
            </h2>
            <p class="text-xl leading-relaxed">
                Hear from the families and individuals who trust us with their care
            </p>
        </div>

        <div class="grid md:grid-cols-3 lg:grid-cols-3 gap-8">
            {testimonials.map((testimonial) => (
                    <div class="bg-green-dark text-white rounded-2xl p-8 hover:shadow-lg transition-all duration-300 flex flex-col">
                        <div class="mb-6">
                            <svg class="w-10 h-10" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
                            </svg>
                        </div>

                        <blockquote class="leading-relaxed mb-6 grow">
                            "{testimonial.quote}"
                        </blockquote>

                        <div class="pt-4 border-t border-gray-200">
                            <p class="font-semibold mb-1">{testimonial.name}</p>
                            <p class="text-sm">{testimonial.relationship} • {testimonial.service}</p>
                        </div>

                        <div class="flex gap-1 mt-4">
                            {[...Array(5)].map(() => (
                                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                                    </svg>
                            ))}
                        </div>
                    </div>
            ))}
        </div>

        <div class="mt-16 text-center">
            <div class="inline-flex items-center gap-3 px-6 py-4 bg-green-dark/5 rounded-full">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                </svg>
                <span class="font-medium">
                    Trusted by over 5,000 families across the region
                </span>
            </div>
        </div>
    </div>
</section>
