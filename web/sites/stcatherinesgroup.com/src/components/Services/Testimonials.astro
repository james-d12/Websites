---
import SectionHeading from "./SectionHeading.astro";
interface Testimonial {
    quote: string;
    name: string;
    relationship: string;
    service: string;
}

interface Props {
    testimonials: Testimonial[];
}

const {testimonials} = Astro.props;
---

<section class="py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-3xl mx-auto text-center mb-16">
            <SectionHeading
                    title="What People Say"
                    subTitle="Testimonials"
                    description="Hear from the families and individuals who trust us with their care"/>
        </div>

        <div class="grid md:grid-cols-3 lg:grid-cols-3 gap-8">
            {testimonials.map((testimonial) => (
                    <div class="bg-green-dark text-white rounded-2xl p-8 hover:shadow-lg transition-all duration-300 flex flex-col">
                        <div class="mb-6">
                            <svg class="w-10 h-10" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
                            </svg>
                        </div>

                        <blockquote class="leading-relaxed text-lg mb-6 grow">
                            "{testimonial.quote}"
                        </blockquote>

                        <div class="pt-4 border-t border-gray-200">
                            <p class="font-semibold mb-1">{testimonial.name}</p>
                            <p class="text-sm">{testimonial.relationship} • {testimonial.service}</p>
                        </div>

                        <div class="flex gap-1 mt-4">
                            {[...Array(5)].map(() => (
                                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                                    </svg>
                            ))}
                        </div>
                    </div>
            ))}
        </div>
    </div>
</section>
