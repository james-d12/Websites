---
import SectionHeading from "./SectionHeading.astro";
interface Testimonial {
    quote: string;
    name: string;
    relationship: string;
    service: string;
}

interface Props {
    testimonials: Testimonial[];
}

const {testimonials} = Astro.props;
---

<section class="py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-3xl mx-auto text-center mb-16">
            <SectionHeading
                    title="What People Say"
                    subTitle="Testimonials"
                    description="Hear from the families and individuals who trust us with their care"/>
        </div>

        <div class="grid md:grid-cols-3 lg:grid-cols-3 gap-8">
            {testimonials.map((testimonial) => (
                    <div class="bg-green-dark text-white rounded-2xl p-8 hover:shadow-lg transition-all duration-300 flex flex-col">
                        <div class="mb-6">
                            <svg class="w-10 h-10" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
                            </svg>
                        </div>

                        <blockquote class="leading-relaxed text-xl mb-6 grow">
                            "{testimonial.quote}"
                        </blockquote>

                        <div class="pt-4 border-t border-gray-200">
                            <p class="font-semibold mb-1 text-lg">{testimonial.name}</p>
                            <p class="text-md">{testimonial.relationship} • {testimonial.service}</p>
                        </div>
                    </div>
            ))}
        </div>
    </div>
</section>
