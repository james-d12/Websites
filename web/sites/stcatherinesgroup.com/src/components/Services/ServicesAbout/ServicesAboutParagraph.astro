---
interface Props {
    title: string;
}

const {title} = Astro.props;
---

<div class="flex gap-3 sm:gap-4 items-center mb-4">
    <div class="shrink-0 w-8 h-8 sm:w-12 sm:h-12 rounded-xl bg-green-dark/10 flex items-center justify-center">
        <slot name="icon"/>
    </div>

    <h3 class="text-2xl md:text-4xl text-gray-900 underline decoration-green-dark">
        {title}
    </h3>
</div>

<div class="text-base md:text-2xl leading-relaxed text-gray-600 sm:pl-16">
    <slot/>
</div>