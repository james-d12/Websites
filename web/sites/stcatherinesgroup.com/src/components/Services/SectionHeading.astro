---
interface Props {
    subTitle: string;
    title: string;
    description?: string;
}

const {subTitle, title, description} = Astro.props;
---
<div class="text-center mb-16">
    <p class="text-green-dark text-xl font-medium tracking-[0.2em] uppercase mb-4">{subTitle}</p>
    <h2 class="text-gray-900 text-5xl md:text-6xl lg:text-7xl font-bold mb-6">{title}</h2>
    <p class="text-gray-900 text-xl leading-relaxed">
        {description}
    </p>
</div>
