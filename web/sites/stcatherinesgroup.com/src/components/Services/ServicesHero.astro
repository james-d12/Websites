---
import {Image} from "astro:assets";

interface Props {
    label: string;
    title: string;
    description: string;
    image: ImageMetadata;
    imageAlt: string;
}

const {label, title, description, image, imageAlt} = Astro.props;
---

<section class="relative bg-linear-to-b from-white to-warm-50 py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
            <div class="space-y-8">
                <div>
                    <h2 class="text-green-dark text-xl tracking-[0.2em] uppercase mb-4">
                        {label}
                    </h2>
                    <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-gray-900 mb-6">
                        {title}
                    </h1>
                    <p class="text-gray-600 text-xl md:text-3xl leading-relaxed">
                        {description}
                    </p>
                </div>

                <a
                        href="#about"
                        class="inline-flex items-center gap-2 sm:gap-3 px-6 sm:px-8 py-4 sm:py-5 bg-green-dark text-white text-xl sm:text-3xl rounded-lg hover:bg-green-dark/90 transition-all duration-200 group shadow-lg"
                >
                    <span>About This Service</span>
                    <svg class="w-5 h-5 sm:w-6 sm:h-6 group-hover:translate-y-1 transition-transform" fill="none"
                         stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
                    </svg>
                </a>
            </div>

            <div class="relative">
                <div class="absolute -inset-4 bg-linear-to-br from-green-dark/5 to-green-dark/10 rounded-3xl transform rotate-2"></div>
                <div class="relative overflow-hidden rounded-2xl aspect-4/3 shadow-2xl">
                    <Image
                            src={image}
                            alt={imageAlt}
                            format="avif"
                            class="w-full h-full object-cover"
                    />
                </div>
            </div>
        </div>
    </div>
</section>
