---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import Heading from "./Heading.astro";

const entries = (await getCollection("services")).sort(
    (a: CollectionEntry<"services">, b: CollectionEntry<"services">) =>
        a.data.listing.order - b.data.listing.order
);
---

<section id="services" class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-6">

        <Heading title="Our 1-1 Services" subTitle="What We Offer">
            Each of our services is delivered on a one-to-one basis, giving you
            the dedicated time and attention that makes the difference.
        </Heading>

        <div class="relative max-w-7xl mx-auto">
            {entries.map((entry: CollectionEntry<"services">, i: number) => (
                    <div class="relative">
                        {i < entries.length - 1 && (
                                <div class="hidden md:block absolute left-0 right-0 -bottom-20 h-42 pointer-events-none z-10">
                                    <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
                                        <path
                                                d={i % 2 === 0
                                                    ? "M 20 0 C 20 40, 20 60, 50 70 C 65 75, 80 80, 80 100"
                                                    : "M 80 0 C 80 40, 80 60, 50 70 C 35 75, 20 80, 20 100"}
                                                stroke="#13705B"
                                                stroke-width="2.5"
                                                stroke-linecap="round"
                                                fill="none"
                                        />
                                    </svg>
                                </div>
                        )}

                        <a
                                href={`/services/${entry.id}`}
                                class={`group grid md:grid-cols-2 gap-8 md:gap-16 items-center py-16 md:py-20 px-6 md:px-8 ${i % 2 === 1 ? 'md:grid-flow-dense' : ''}`}
                        >
                            <div class={`relative ${i % 2 === 1 ? 'md:col-start-2' : ''}`}>
                                <div class="hidden md:flex absolute -top-4 -left-4 w-16 h-16 rounded-full bg-green-dark items-center justify-center z-20 shadow-lg ring-4 ring-white">
                                    <span class="text-white font-bold text-xl">0{i + 1}</span>
                                </div>

                                <div class="absolute -inset-4 bg-linear-to-br from-green-dark/5 to-green-dark/10 rounded-3xl transform -rotate-2 group-hover:rotate-0 transition-transform duration-500"></div>
                                <div class="relative overflow-hidden rounded-2xl aspect-4/3 shadow-xl">
                                    <Image
                                            src={entry.data.listing.image}
                                            alt={entry.data.hero.title}
                                            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                                    />
                                </div>
                            </div>

                            <div class={`${i % 2 === 1 ? 'md:col-start-1 md:row-start-1' : ''}`}>
                                <div class="inline-block md:hidden px-4 py-2 bg-green-dark/10 rounded-lg mb-6">
                                    <span class="text-green-dark font-semibold text-sm">0{i + 1}</span>
                                </div>
                                <h3 class="text-4xl md:text-6xl font-bold text-green-dark mb-6 group-hover:text-green-dark transition-colors">
                                    {entry.data.hero.title}
                                </h3>
                                <p class="text-green-dark text-2xl md:text-3xl leading-relaxed mb-8">
                                    {entry.data.hero.description}
                                </p>
                                <span class="inline-flex items-center px-6 py-3 bg-green-dark text-white font-medium text-lg md:text-2xl rounded-lg group-hover:bg-green-dark/90 transition-all shadow-md">
                                    Learn more
                                    <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none"
                                         stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M9 5l7 7-7 7"/>
                                    </svg>
                                </span>
                            </div>
                        </a>
                    </div>
            ))}
        </div>
    </div>
</section>
