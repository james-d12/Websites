---
interface Props {
    class?: string;
}

const { class: className = "" } = Astro.props;

const gradientId = `section-divider-gradient-${Math.random().toString(36).slice(2, 9)}`;
---

<div class={`w-full bg-white flex justify-center py-10 md:py-14 ${className}`}>
    <svg
        class="w-full h-14 md:h-20"
        viewBox="0 0 300 48"
        preserveAspectRatio="none"
        fill="none"
        aria-hidden="true"
    >
        <defs>
            <linearGradient id={gradientId} x1="0" y1="0" x2="1" y2="0">
                <stop offset="0%" stop-color="#0c4438" />
                <stop offset="50%" stop-color="#13705b" />
                <stop offset="100%" stop-color="#0c4438" />
            </linearGradient>
        </defs>
        <path
            d="M0,24 C30,12 45,36 75,24 C105,12 120,36 150,24 C180,12 195,36 225,24 C255,12 270,36 300,24"
            stroke={`url(#${gradientId})`}
            stroke-width="16"
            stroke-linecap="round"
            vector-effect="non-scaling-stroke"
            fill="none"
        />
    </svg>
</div>
