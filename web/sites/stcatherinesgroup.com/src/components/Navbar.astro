---
import favicon from "../assets/favicon.ico";

const services = [
    {name: "1-1 Chaperone Carer", href: "/services/1-1-chaperone-carer"},
    {name: "1-1 Companionship Carer", href: "/services/1-1-companionship-carer"},
    {name: "1-1 Dementia Carer", href: "/services/1-1-dementia-carer"},
    {name: "1-1 Safety Carer", href: "/services/1-1-safety-carer"},
    {name: "Personal Assistants", href: "/services/personal-assistants"},
];

const nurses = [
    {name: "Vaccination Nurses", href: "/nurses/vaccination-nurses"},
    {name: "Care Home Nurses", href: "/nurses/carehome-nurses"},
    {name: "Hospital Nurses", href: "/nurses/hospital-nurses"},
    {name: "Practice Nurses", href: "/nurses/practice-nurses"},
]

const navLinks = [
    {name: "About Us", href: "/about-us"},
    {name: "1-1 Carer Services", dropdown: services},
    {name: "Nurses", dropdown: nurses},
    {name: "Contact Us", href: "/contact"},
];
---

<div class="sticky top-0 left-0 w-full z-50">
    <div class="hidden md:block w-full bg-green-darker py-1.5 px-4 sm:px-8">
        <div class="max-w-8xl mx-auto flex items-center justify-center gap-6">
            <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-white/70 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
                <a href="tel:+442036633074" class="text-white/80 hover:text-white text-sm tracking-wide transition-colors">
                    020 3663 3074
                </a>
            </div>
            <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-white/70 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
                <a href="mailto:clientservices@stcatherinesgroup.com" class="text-white/80 hover:text-white text-sm tracking-wide transition-colors">
                    clientservices@stcatherinesgroup.com
                </a>
            </div>
            <a href="/contact" class="bg-white text-green-darker text-sm font-semibold tracking-wide px-4 py-0.5 rounded hover:bg-white/90 transition-colors">
                Contact Us
            </a>
        </div>
    </div>
<nav class="w-full bg-linear-to-l from-green-dark via-green-dark to-green-darker shadow-md">
    <div class="max-w-8xl mx-auto py-4 lg:py-0 px-2 sm:px-4 md:px-8 flex items-center justify-between">
        <a href="/" class="flex items-center gap-4 md:gap-8 group" title="Home">
            <img src={favicon} alt="St Catherine's Group Logo" class="w-14 h-14 md:w-32 md:h-32"/>
            <div class="grid grid-rows">
                <span class="text-2xl md:text-5xl font-semibold text-white tracking-tight">
                    St Catherine's Group
                </span>
                <span class="text-md md:text-3xl text-white tracking-tight"
                      style="font-family: 'Lora', Georgia, serif;">
                    Healthcare
                </span>
            </div>
        </a>

        <ul class="hidden xl:flex items-center gap-16">
            {navLinks.map(link => (
                    <li class={link.dropdown ? "relative group" : ""}>
                        {link.href ? (
                                <a
                                        title={link.name}
                                        href={link.href}
                                        class="text-3xl font-medium tracking-wide uppercase transition-colors duration-200 text-white hover:text-white/90"
                                >
                                    {link.name}
                                </a>
                        ) : (
                                <span class={`text-3xl font-medium tracking-wide uppercase transition-colors duration-200 text-white cursor-pointer ${link.dropdown ? "flex items-center gap-1" : ""}`}>
                            {link.name}
                                    {link.dropdown && (
                                            <svg class="w-6.5 h-6.5 transition-transform group-hover:rotate-180"
                                                 fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                      d="M19 9l-7 7-7-7"/>
                                            </svg>
                                    )}
                        </span>
                        )}
                        {link.dropdown && (
                                <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
                                    <div class="bg-linear-to-l from-green-dark to-green-dark rounded-lg shadow-lg border border-white/10 py-2 min-w-80">
                                        {link.dropdown.map(item => (
                                                <a
                                                        href={item.href}
                                                        title={item.name}
                                                        class="block px-5 py-2.5 text-2xl text-white hover:bg-white/10 transition-colors"
                                                >
                                                    {item.name}
                                                </a>
                                        ))}
                                    </div>
                                </div>
                        )}
                    </li>
            ))}
        </ul>

        <button
                id="mobile-menu-btn"
                class="xl:hidden flex items-center justify-center w-10 h-10 rounded-lg text-white hover:text-white/80 hover:bg-white/10 transition-colors"
                aria-expanded="false"
                aria-controls="mobile-menu"
                title="Open menu"
        >
            <span id="menu-btn-text" class="sr-only">Open menu</span>
            <svg id="menu-icon-open" class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
            <svg id="menu-icon-close" class="w-12 h-12 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
            </svg>
        </button>
    </div>

    <div id="mobile-menu"
         class="hidden xl:hidden border-t border-white/10 bg-linear-to-l from-green-dark to-green-darker">
        <div class="max-w-6xl mx-auto px-6 py-4 space-y-1">
            {navLinks.map(link => (
                    <div>
                        {link.href ? (
                                <a
                                        href={link.href}
                                        class="block py-2.5 text-sm font-medium tracking-wide uppercase transition-colors text-white hover:text-white/90"
                                >
                                    {link.name}
                                </a>
                        ) : (
                                <span class="block py-2.5 text-sm font-medium tracking-wide uppercase text-white">
                            {link.name}
                        </span>
                        )}
                        {link.dropdown && (
                                <div class="pl-4 space-y-1">
                                    {link.dropdown.map(item => (
                                            <a
                                                    href={item.href}
                                                    class="block py-2 text-sm text-white hover:text-white/90 transition-colors"
                                            >
                                                {item.name}
                                            </a>
                                    ))}
                                </div>
                        )}
                    </div>
            ))}
        </div>
    </div>
</nav>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const btn = document.getElementById("mobile-menu-btn");
        const menu = document.getElementById("mobile-menu");
        const iconOpen = document.getElementById("menu-icon-open");
        const iconClose = document.getElementById("menu-icon-close");
        const btnText = document.getElementById("menu-btn-text");

        if (!btn || !menu || !iconOpen || !iconClose || !btnText) return;

        const toggle = () => {
            const isOpen = !menu.classList.contains("hidden");
            menu.classList.toggle("hidden");
            iconOpen.classList.toggle("hidden");
            iconClose.classList.toggle("hidden");
            btn.setAttribute("aria-expanded", String(!isOpen));

            // Update button text and title for accessibility
            if (!isOpen) {
                btnText.textContent = "Close menu";
                btn.setAttribute("title", "Close menu");
            } else {
                btnText.textContent = "Open menu";
                btn.setAttribute("title", "Open menu");
            }
        };

        btn.addEventListener("click", (e) => {
            e.stopPropagation();
            toggle();
        });

        document.addEventListener("click", (e) => {
            if (!btn.contains(e.target as Node) && !menu.contains(e.target as Node)) {
                if (!menu.classList.contains("hidden")) toggle();
            }
        });

        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape" && !menu.classList.contains("hidden")) toggle();
        });
    });
</script>
