---
import favicon from "../assets/favicon.ico";

const services = [
    { name: "1-1 Chaperone Carer", href: "/services/1-1-chaperone-carer" },
    {
        name: "1-1 Companionship Carer",
        href: "/services/1-1-companionship-carer",
    },
    { name: "1-1 Dementia Carer", href: "/services/1-1-dementia-carer" },
    { name: "1-1 Safety Carer", href: "/services/1-1-safety-carer" },
    { name: "Personal Assistants", href: "/services/personal-assistants" },
];

const nurses = [
    { name: "Care Home Nurses", href: "/nurses/carehome-nurses" },
    { name: "Hospital Nurses", href: "/nurses/hospital-nurses" },
    { name: "Practice Nurses", href: "/nurses/practice-nurses" },
];

const navLinks = [
    { name: "About", href: "/about-us" },
    { name: "Services", dropdown: services },
    { name: "Nurses", dropdown: nurses },
    { name: "Testimonials", href: "/testimonials" },
    { name: "Contact", href: "/contact" },
];
---

<div class="sticky top-0 left-0 w-full z-50">
    <div class="hidden md:block w-full bg-white py-1 px-6 sm:px-8">
        <div class="max-w-8xl mx-auto flex items-center justify-center gap-6">
            <div class="flex items-center gap-2">
                <svg
                    class="w-8 h-8 text-green-darker shrink-0"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                    ></path>
                </svg>
                <a
                    href="tel:+442036633074"
                    class="text-green-darker hover:text-green text-4xl tracking-wide transition-colors"
                >
                    020 3663 3074
                </a>
            </div>
            <a
                href="/contact"
                class="flex items-center gap-2 bg-green text-green-darker text-4xl font-semibold tracking-wide px-6 py-2 rounded transition-colors"
            >
                <svg
                    class="w-8 h-8 shrink-0"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                    ></path>
                </svg>
                Contact Us
            </a>
        </div>
    </div>
    <nav
        class="relative w-full bg-linear-to-l from-green-dark via-green-dark to-green-darker shadow-md"
    >
        <div
            class="max-w-8xl mx-auto py-4 lg:py-0 px-2 sm:px-4 md:px-8 flex items-center justify-between"
        >
            <a
                href="/"
                class="flex items-center gap-4 md:gap-8 group"
                title="Home"
            >
                <img
                    src={favicon}
                    alt="St Catherine's Group Logo"
                    class="w-14 h-14 md:w-24 md:h-24 lg:w-32 lg:h-32"
                />
                <div class="grid grid-rows">
                    <span
                        class="text-2xl md:text-4xl lg:text-6xl text-white tracking-tight lg:whitespace-nowrap"
                    >
                        St Catherine's Group Ltd
                    </span>
                    <span
                        class="text-md md:text-2xl lg:text-3xl text-white tracking-tight"
                        style="font-family: 'Lora', Georgia, serif;"
                    >
                        Healthcare
                    </span>
                </div>
            </a>

            <ul class="hidden 2xl:flex items-center gap-12 ">
                {
                    navLinks.map((link) => (
                        <li class={link.dropdown ? "relative group" : ""}>
                            {link.href ? (
                                <a
                                    title={link.name}
                                    href={link.href}
                                    class="text-xl lg:text-2xl tracking-wide uppercase transition-colors duration-200 text-white hover:text-white/90"
                                >
                                    {link.name}
                                </a>
                            ) : (
                                <span
                                    class={`text-xl md:text-2xl tracking-wide uppercase transition-colors duration-200 text-white cursor-pointer ${link.dropdown ? "flex items-center gap-1" : ""}`}
                                >
                                    {link.name}
                                    {link.dropdown && (
                                        <svg
                                            class="w-6.5 h-6.5 transition-transform group-hover:rotate-180"
                                            fill="none"
                                            stroke="currentColor"
                                            viewBox="0 0 24 24"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M19 9l-7 7-7-7"
                                            />
                                        </svg>
                                    )}
                                </span>
                            )}
                            {link.dropdown && (
                                <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
                                    <div class="bg-linear-to-l from-green-dark to-green-dark rounded-lg shadow-lg border border-white/10 py-2 min-w-80">
                                        {link.dropdown.map((item) => (
                                            <a
                                                href={item.href}
                                                title={item.name}
                                                class="block px-5 py-2.5 text-2xl text-white hover:bg-white/10 transition-colors"
                                            >
                                                {item.name}
                                            </a>
                                        ))}
                                    </div>
                                </div>
                            )}
                        </li>
                    ))
                }
            </ul>

            <button
                id="mobile-menu-btn"
                class="2xl:hidden flex items-center justify-center w-14 h-14 rounded-lg text-white hover:text-white/80 hover:bg-white/10 transition-colors"
                aria-expanded="false"
                aria-controls="mobile-menu"
                title="Open menu"
            >
                <span id="menu-btn-text" class="sr-only">Open menu</span>

                <svg
                    id="menu-icon-open"
                    class="w-12 h-12"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="1.5"
                        d="M4 6h16M4 12h16M4 18h16"
                    >
                    </path>
                </svg>

                <svg
                    id="menu-icon-close"
                    class="w-12 h-12 hidden"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="1.5"
                        d="M6 18L18 6M6 6l12 12"
                    >
                    </path>
                </svg>
            </button>
        </div>

        <div
            id="mobile-menu"
            class="hidden 2xl:hidden absolute top-full left-0 w-full z-40 max-h-[80vh] overflow-y-auto border-t border-white/10 bg-linear-to-l from-green-dark via-green-dark to-green-darker shadow-lg"
        >
            <div class="max-w-6xl mx-auto px-6 py-2 divide-y divide-white/10">
                {
                    navLinks.map((link) => (
                        <div class="py-0.5 first:pt-0 last:pb-0">
                            {link.href ? (
                                <a
                                    href={link.href}
                                    class="block py-2 text-xl font-semibold tracking-wide uppercase transition-colors text-white hover:text-white/80"
                                >
                                    {link.name}
                                </a>
                            ) : (
                                <button
                                    type="button"
                                    class="mobile-dropdown-toggle flex items-center justify-between gap-2 w-full py-2 text-xl font-semibold tracking-wide uppercase text-white"
                                    aria-expanded="false"
                                    aria-controls={`mobile-dropdown-${link.name.toLowerCase().replace(/\s+/g, "-")}`}
                                >
                                    {link.name}
                                    <svg
                                        class="mobile-dropdown-chevron w-6 h-6 shrink-0 transition-transform"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M19 9l-7 7-7-7"
                                        />
                                    </svg>
                                </button>
                            )}
                            {link.dropdown && (
                                <div
                                    id={`mobile-dropdown-${link.name.toLowerCase().replace(/\s+/g, "-")}`}
                                    class="mobile-dropdown-panel hidden mb-1.5 rounded-lg bg-black/15"
                                >
                                    {link.dropdown.map((item) => (
                                        <a
                                            href={item.href}
                                            class="block px-4 py-1.5 text-xl text-white/90 hover:bg-white/10 hover:text-white rounded-lg transition-colors"
                                        >
                                            {item.name}
                                        </a>
                                    ))}
                                </div>
                            )}
                        </div>
                    ))
                }
            </div>
        </div>
    </nav>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const btn = document.getElementById("mobile-menu-btn");
        const menu = document.getElementById("mobile-menu");
        const iconOpen = document.getElementById("menu-icon-open");
        const iconClose = document.getElementById("menu-icon-close");
        const btnText = document.getElementById("menu-btn-text");

        if (!btn || !menu || !iconOpen || !iconClose || !btnText) return;

        let scrollY = 0;

        // position: fixed lock (rather than overflow: hidden) avoids iOS
        // Safari's background rubber-band scroll bleeding through the overlay
        const lockScroll = () => {
            scrollY = window.scrollY;
            document.body.style.position = "fixed";
            document.body.style.top = `-${scrollY}px`;
            document.body.style.left = "0";
            document.body.style.right = "0";
            document.body.style.width = "100%";
        };

        const unlockScroll = () => {
            document.body.style.position = "";
            document.body.style.top = "";
            document.body.style.left = "";
            document.body.style.right = "";
            document.body.style.width = "";
            window.scrollTo(0, scrollY);
        };

        const dropdownToggles = menu.querySelectorAll<HTMLButtonElement>(
            ".mobile-dropdown-toggle",
        );

        const collapseDropdowns = () => {
            dropdownToggles.forEach((dropdownBtn) => {
                dropdownBtn.setAttribute("aria-expanded", "false");
                dropdownBtn
                    .querySelector(".mobile-dropdown-chevron")
                    ?.classList.remove("rotate-180");

                const panelId = dropdownBtn.getAttribute("aria-controls");
                const panel = panelId && document.getElementById(panelId);
                panel?.classList.add("hidden");
            });
        };

        dropdownToggles.forEach((dropdownBtn) => {
            dropdownBtn.addEventListener("click", () => {
                const isExpanded =
                    dropdownBtn.getAttribute("aria-expanded") === "true";
                const panelId = dropdownBtn.getAttribute("aria-controls");
                const panel = panelId && document.getElementById(panelId);
                if (!panel) return;

                dropdownBtn.setAttribute("aria-expanded", String(!isExpanded));
                panel.classList.toggle("hidden");
                dropdownBtn
                    .querySelector(".mobile-dropdown-chevron")
                    ?.classList.toggle("rotate-180");
            });
        });

        const toggle = () => {
            const isOpen = !menu.classList.contains("hidden");
            menu.classList.toggle("hidden");
            iconOpen.classList.toggle("hidden");
            iconClose.classList.toggle("hidden");
            btn.setAttribute("aria-expanded", String(!isOpen));

            if (isOpen) {
                unlockScroll();
                collapseDropdowns();
            } else {
                lockScroll();
            }

            // Update button text and title for accessibility
            if (!isOpen) {
                btnText.textContent = "Close menu";
                btn.setAttribute("title", "Close menu");
            } else {
                btnText.textContent = "Open menu";
                btn.setAttribute("title", "Open menu");
            }
        };

        btn.addEventListener("click", (e) => {
            e.stopPropagation();
            toggle();
        });

        document.addEventListener("click", (e) => {
            if (
                !btn.contains(e.target as Node) &&
                !menu.contains(e.target as Node)
            ) {
                if (!menu.classList.contains("hidden")) toggle();
            }
        });

        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape" && !menu.classList.contains("hidden"))
                toggle();
        });
    });
</script>
