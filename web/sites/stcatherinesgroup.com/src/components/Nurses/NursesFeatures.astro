---
import type { NurseFeatureCard } from "../../content.config";

interface Props {
    eyebrow: string;
    title: string;
    description: string;
    cards: NurseFeatureCard[];
    background?: string;
}

const {
    eyebrow,
    title,
    description,
    cards,
    background = "bg-white",
} = Astro.props;
---

<section class={`py-20 md:py-28 ${background}`}>
    <div class="max-w-6xl mx-auto px-6">
        <div class="text-center mb-16">
            <h3
                class="inline-flex items-center gap-2 px-4 md:px-6 py-2 md:py-4 mb-6 bg-green-dark text-white font-semibold text-3xl md:text-4xl rounded-lg group shadow-lg"
            >
                {eyebrow}
            </h3>

            <h2
                class="text-green-dark text-5xl md:text-6xl lg:text-7xl font-bold mb-6"
            >
                {title}
            </h2>
            <p class="text-green-dark text-3xl leading-relaxed">
                {description}
            </p>
        </div>

        <div class="space-y-8">
            <div class="grid md:grid-cols-2 gap-8">
                {
                    cards.map((card) => (
                        <div class="bg-warm-50 rounded-xl p-8">
                            <div class="flex items-start gap-4 mb-4">
                                <div class="w-14 h-14 rounded-lg bg-green-dark flex items-center justify-center shrink-0">
                                    <svg
                                        class="w-10 h-10 text-white"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d={card.icon}
                                        />
                                    </svg>
                                </div>
                                <div>
                                    <h3 class="text-2xl md:text-4xl text-green-dark mb-3">
                                        {card.title}
                                    </h3>
                                    <p class="text-xl md:text-xl text-green-dark leading-relaxed mb-3">
                                        {card.body}
                                    </p>
                                    <ul class="space-y-2 text-green-dark text-lg md:text-xl">
                                        {card.items.map((item) => (
                                            <li class="flex items-start gap-2">
                                                <span class="text-green-dark">
                                                    →
                                                </span>
                                                <span>{item}</span>
                                            </li>
                                        ))}
                                    </ul>
                                </div>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </div>
</section>
