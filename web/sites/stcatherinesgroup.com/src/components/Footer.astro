---
const year = new Date().getFullYear();

const serviceLinks = [
    { name: "Companionship", href: "/services/companionship" },
    { name: "Chaperone", href: "/services/chaperone" },
    { name: "Dementia", href: "/services/dementia" },
    { name: "1-1 Safety", href: "/services/1-1-safety" },
    { name: "Personal Assistant", href: "/services/personal-assistant" },
];

const quickLinks = [
    { name: "About Us", href: "/about" },
    { name: "Contact Us", href: "/contact" },
    { name: "Blog", href: "/blog" },
];
---

<footer class="bg-green-dark text-white">
    <div class="max-w-6xl mx-auto px-6 py-8">
        <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-6">
            <h2 class="text-lg font-semibold text-white" style="font-family: 'Lora', Georgia, serif;">
                St Catherine's Group
            </h2>
            <div class="flex flex-wrap gap-x-6 gap-y-1 text-sm text-white">
                {serviceLinks.map(link => (
                    <a href={link.href} class="hover:text-white transition-colors">{link.name}</a>
                ))}
            </div>
            <div class="flex flex-wrap gap-x-6 gap-y-1 text-sm text-white">
                {quickLinks.map(link => (
                    <a href={link.href} class="hover:text-white transition-colors">{link.name}</a>
                ))}
            </div>
        </div>
    </div>
    <div class="border-t border-white/10">
        <div class="max-w-6xl mx-auto px-6 py-3 flex flex-col sm:flex-row justify-between items-center gap-1">
            <p class="text-xs text-white">&copy; {year} St Catherine's Group. All rights reserved.</p>
            <p class="text-xs text-white">Dedicated to exceptional care.</p>
        </div>
    </div>
</footer>
