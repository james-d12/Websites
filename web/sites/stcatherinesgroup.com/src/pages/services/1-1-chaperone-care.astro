---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CallToAction from '../../components/CallToAction.astro';
import {Image} from "astro:assets";
import chaperoneImage from "../../assets/thiago-cerqueira-Wr3HGvx_RSM-unsplash.jpg";

const testimonials = [
    {
        quote: "The care and attention my mother receives is truly exceptional. Her companion has become like family to us, and we see such a positive change in Mum's wellbeing and happiness.",
        name: "Sarah M.",
        relationship: "Daughter",
        service: "Companionship"
    },
    {
        quote: "Having someone accompany me to medical appointments has made such a difference. I feel confident asking questions and never worry about forgetting important information anymore.",
        name: "Robert T.",
        relationship: "Client",
        service: "Chaperone"
    },
    {
        quote: "The dementia care team understands my husband in a way that brings me such relief. They're patient, kind, and genuinely care about making his days meaningful and joyful.",
        name: "Margaret L.",
        relationship: "Wife",
        service: "Dementia Care"
    }
];
---

<Layout title="1-1 Chaperone Care - St Catherine's Group" description="Reliable, discreet support for appointments, outings, and events so you never have to go alone.">
    <Navbar />

    <!-- Hero Section -->
    <section class="relative bg-linear-to-b from-white to-warm-50 py-20 md:py-28">
        <div class="max-w-7xl mx-auto px-6">
            <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
                <div class="space-y-8">
                    <div>
                        <p class="text-green-dark text-sm font-medium tracking-[0.2em] uppercase mb-4">
                            Our Services
                        </p>
                        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-gray-900 mb-6">
                            1-1 Chaperone Care
                        </h1>
                        <p class="text-gray-600 text-xl md:text-2xl leading-relaxed">
                            Reliable, discreet support for appointments, outings, and events so you never have to go alone. From medical appointments to social gatherings, shopping trips to family occasions, we provide the reassuring presence that helps you feel confident and comfortable wherever you need to be.
                        </p>
                    </div>
                </div>

                <div class="relative">
                    <div class="absolute -inset-4 bg-linear-to-br from-green-dark/5 to-green-dark/10 rounded-3xl transform rotate-2"></div>
                    <div class="relative overflow-hidden rounded-2xl aspect-4/3 shadow-2xl">
                        <Image
                            src={chaperoneImage}
                            alt="Chaperone services"
                            class="w-full h-full object-cover"
                        />
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- How It Works Section -->
    <section class="py-20 md:py-28 bg-white">
        <div class="max-w-5xl mx-auto px-6">
            <div class="text-center mb-16">
                <p class="text-green-dark text-sm font-medium tracking-[0.2em] uppercase mb-4">The Journey</p>
                <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
                    From Start to Finish, We're With You
                </h2>
                <p class="text-gray-600 text-lg leading-relaxed max-w-3xl mx-auto">
                    Our chaperone service provides seamless support throughout your entire appointment or outing, so you can focus on what matters.
                </p>
            </div>

            <div class="relative">
                <div class="hidden md:block absolute left-1/2 top-0 bottom-0 w-0.5 bg-green-dark/20 -ml-px"></div>

                <div class="space-y-12">
                    <div class="md:grid md:grid-cols-2 md:gap-12 items-center">
                        <div class="md:text-right mb-8 md:mb-0">
                            <div class="inline-block md:block">
                                <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-green-dark text-white font-bold mb-4">1</span>
                                <h3 class="text-2xl font-bold text-gray-900 mb-3">Before We Go</h3>
                                <p class="text-gray-600 leading-relaxed">
                                    We'll confirm all the details - appointment time, location, what you need help with, and any special requirements. We arrive early, ready to support you.
                                </p>
                            </div>
                        </div>
                        <div class="hidden md:block"></div>
                    </div>

                    <div class="md:grid md:grid-cols-2 md:gap-12 items-center">
                        <div class="hidden md:block"></div>
                        <div class="mb-8 md:mb-0">
                            <div class="inline-block md:block">
                                <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-green-dark text-white font-bold mb-4">2</span>
                                <h3 class="text-2xl font-bold text-gray-900 mb-3">Getting There</h3>
                                <p class="text-gray-600 leading-relaxed">
                                    Whether driving, taking public transport, or walking, we provide support navigating to your destination safely and comfortably.
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="md:grid md:grid-cols-2 md:gap-12 items-center">
                        <div class="md:text-right mb-8 md:mb-0">
                            <div class="inline-block md:block">
                                <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-green-dark text-white font-bold mb-4">3</span>
                                <h3 class="text-2xl font-bold text-gray-900 mb-3">During the Appointment</h3>
                                <p class="text-gray-600 leading-relaxed">
                                    We're by your side - helping you ask questions, remember information, take notes, and ensuring you understand everything clearly.
                                </p>
                            </div>
                        </div>
                        <div class="hidden md:block"></div>
                    </div>

                    <div class="md:grid md:grid-cols-2 md:gap-12 items-center">
                        <div class="hidden md:block"></div>
                        <div>
                            <div class="inline-block reshuffle pages based on client feedbackmd:block">
                                <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-green-dark text-white font-bold mb-4">4</span>
                                <h3 class="text-2xl font-bold text-gray-900 mb-3">Safe Return Home</h3>
                                <p class="text-gray-600 leading-relaxed">
                                    We ensure you get home safely and help you process any instructions or next steps from your appointment.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    
    <section>
          <div class="max-w-7xl mx-auto px-6">
            <div class="max-w-3xl mx-auto text-center mb-16">
                <p class="text-sm font-medium tracking-[0.2em] uppercase mb-4">Testimonials</p>
                <h2 class="text-5xl md:text-6xl lg:text-7xl font-bold  mb-6">
                    What People Say
                </h2>
                <p class="text-xl leading-relaxed">
                    Hear from the families and individuals who trust us with their care
                </p>
            </div>

            <div class="grid md:grid-cols-3 lg:grid-cols-3 gap-8">
                {testimonials.map((testimonial) => (
                    <div class="bg-green-dark text-white rounded-2xl p-8 hover:shadow-lg transition-all duration-300 flex flex-col">
                        <!-- Quote Icon -->
                        <div class="mb-6">
                            <svg class="w-10 h-10" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
                            </svg>
                        </div>

                        <!-- Quote Text -->
                        <blockquote class="leading-relaxed mb-6 grow">
                            "{testimonial.quote}"
                        </blockquote>

                        <!-- Author Info -->
                        <div class="pt-4 border-t border-gray-200">
                            <p class="font-semibold mb-1">{testimonial.name}</p>
                            <p class="text-sm">{testimonial.relationship} • {testimonial.service}</p>
                        </div>

                        <!-- Star Rating -->
                        <div class="flex gap-1 mt-4">
                            {[...Array(5)].map(() => (
                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                </svg>
                            ))}
                        </div>
                    </div>
                ))}
            </div>

            <!-- Trust Badge -->
            <div class="mt-16 text-center">
                <div class="inline-flex items-center gap-3 px-6 py-4 bg-green-dark/5 rounded-full">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                    </svg>
                    <span class="font-medium">
                        Trusted by over 5,000 families across the region
                    </span>
                </div>
            </div>
        </div>
    </section>

    <!-- Where We Support Section -->
    <section class="py-20 md:py-28 bg-warm-50">
        <div class="max-w-6xl mx-auto px-6">
            <div class="text-center mb-16">
                <p class="text-green-dark text-sm font-medium tracking-[0.2em] uppercase mb-4">Wherever You Need Us</p>
                <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
                    We Accompany You To
                </h2>
            </div>

            <div class="grid md:grid-cols-2 gap-6">
                <div class="group bg-white rounded-xl p-6 hover:shadow-lg transition-all">
                    <div class="flex items-start gap-4">
                        <div class="shrink-0 w-12 h-12 rounded-lg bg-green-dark/10 flex items-center justify-center group-hover:bg-green-dark group-hover:scale-110 transition-all">
                            <svg class="w-6 h-6 text-green-dark group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                            </svg>
                        </div>
                        <div>
                            <h3 class="text-xl font-bold text-gray-900 mb-2">Medical Appointments</h3>
                            <p class="text-gray-600">GP surgeries, hospitals, specialists, diagnostic tests, treatment sessions</p>
                        </div>
                    </div>
                </div>

                <div class="group bg-white rounded-xl p-6 hover:shadow-lg transition-all">
                    <div class="flex items-start gap-4">
                        <div class="shrink-0 w-12 h-12 rounded-lg bg-green-dark/10 flex items-center justify-center group-hover:bg-green-dark group-hover:scale-110 transition-all">
                            <svg class="w-6 h-6 text-green-dark group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                            </svg>
                        </div>
                        <div>
                            <h3 class="text-xl font-bold text-gray-900 mb-2">Professional Meetings</h3>
                            <p class="text-gray-600">Legal consultations, financial advisors, estate agents, care assessments</p>
                        </div>
                    </div>
                </div>

                <div class="group bg-white rounded-xl p-6 hover:shadow-lg transition-all">
                    <div class="flex items-start gap-4">
                        <div class="shrink-0 w-12 h-12 rounded-lg bg-green-dark/10 flex items-center justify-center group-hover:bg-green-dark group-hover:scale-110 transition-all">
                            <svg class="w-6 h-6 text-green-dark group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                            </svg>
                        </div>
                        <div>
                            <h3 class="text-xl font-bold text-gray-900 mb-2">Social Occasions</h3>
                            <p class="text-gray-600">Family gatherings, weddings, community events, religious services</p>
                        </div>
                    </div>
                </div>

                <div class="group bg-white rounded-xl p-6 hover:shadow-lg transition-all">
                    <div class="flex items-start gap-4">
                        <div class="shrink-0 w-12 h-12 rounded-lg bg-green-dark/10 flex items-center justify-center group-hover:bg-green-dark group-hover:scale-110 transition-all">
                            <svg class="w-6 h-6 text-green-dark group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                            </svg>
                        </div>
                        <div>
                            <h3 class="text-xl font-bold text-gray-900 mb-2">Shopping & Errands</h3>
                            <p class="text-gray-600">Grocery shopping, pharmacy visits, retail stores, post office</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <CallToAction />
    <Footer />
</Layout>
