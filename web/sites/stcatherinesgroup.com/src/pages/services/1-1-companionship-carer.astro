---
import { getEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CallToAction from '../../components/CallToAction.astro';
import companionshipImage from "../../assets/companionship-carer.jpg";
import * as ServiceComponent from "../../components/Services";

const entry = await getEntry('services', '1-1-companionship-carer');
if (!entry) throw new Error('Service content not found: 1-1-companionship-carer');
const { meta, hero, about, testimonials, testimonialsBackground, ctaBackground } = entry.data;
---

<Layout title={meta.title} description={meta.description}>
    <Navbar/>

    <main>
        <ServiceComponent.ServicesHero
                label={hero.label}
                title={hero.title}
                description={hero.description}
                image={companionshipImage}
                imageAlt={hero.imageAlt}
        />

        <ServiceComponent.ServicesAbout
                title={about.title}
                subTitle={about.subTitle}
                sections={about.sections}
                callout={about.callout}
        />

        <ServiceComponent.ServicesStory entry={entry}/>

        <ServiceComponent.ServicesTestimonials testimonials={testimonials} background={testimonialsBackground}/>

        <CallToAction background={ctaBackground}/>
    </main>

    <Footer/>
</Layout>
