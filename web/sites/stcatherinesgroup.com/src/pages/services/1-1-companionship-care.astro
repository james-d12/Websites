---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CallToAction from '../../components/CallToAction.astro';
import {Image} from "astro:assets";
import companionshipImage from "../../assets/national-cancer-institute-BxXgTQEw1M4-unsplash.jpg";
---

<Layout title="1-1 Companionship Care - St Catherine's Group" description="Genuine, meaningful companionship that brings comfort, conversation, and connection into everyday life.">
    <Navbar />

    <!-- Hero Section -->
    <section class="relative bg-linear-to-b from-white to-warm-50 py-20 md:py-28">
        <div class="max-w-7xl mx-auto px-6">
            <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
                <div class="space-y-8">
                    <div>
                        <p class="text-green-dark text-sm font-medium tracking-[0.2em] uppercase mb-4">
                            Our Services
                        </p>
                        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-gray-900 mb-6">
                            1-1 Companionship Care
                        </h1>
                        <p class="text-gray-600 text-xl md:text-2xl leading-relaxed">
                            Genuine, meaningful companionship that brings comfort, conversation, and connection into everyday life. Whether it's sharing stories over a cup of tea, enjoying a walk together, or simply having someone to talk to, our companions are here to brighten your day and provide the human connection that matters most.
                        </p>
                    </div>
                </div>

                <div class="relative">
                    <div class="absolute -inset-4 bg-linear-to-br from-green-dark/5 to-green-dark/10 rounded-3xl transform rotate-2"></div>
                    <div class="relative overflow-hidden rounded-2xl aspect-4/3 shadow-2xl">
                        <Image
                            src={companionshipImage}
                            alt="Companionship services"
                            class="w-full h-full object-cover"
                        />
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- A Typical Day Section -->
    <section class="py-20 md:py-28 bg-white">
        <div class="max-w-6xl mx-auto px-6">
            <div class="grid lg:grid-cols-2 gap-16 items-start">
                <div class="sticky top-8">
                    <p class="text-green-dark text-sm font-medium tracking-[0.2em] uppercase mb-4">What We Do Together</p>
                    <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
                        A Day in the Life
                    </h2>
                    <p class="text-gray-600 text-lg leading-relaxed">
                        Every visit is unique and tailored to you. Here's a glimpse of the meaningful moments we create together through genuine companionship.
                    </p>
                </div>

                <div class="space-y-8">
                    <div class="relative pl-8 border-l-2 border-green-dark/20">
                        <div class="absolute -left-3 top-0 w-5 h-5 rounded-full bg-green-dark"></div>
                        <h3 class="text-2xl font-bold text-gray-900 mb-3">Morning Coffee & Conversation</h3>
                        <p class="text-gray-600 leading-relaxed">
                            We start with a warm cup of tea or coffee, catching up on the week, sharing stories, and discussing whatever's on your mind - from current events to cherished memories.
                        </p>
                    </div>

                    <div class="relative pl-8 border-l-2 border-green-dark/20">
                        <div class="absolute -left-3 top-0 w-5 h-5 rounded-full bg-green-dark"></div>
                        <h3 class="text-2xl font-bold text-gray-900 mb-3">Shared Activities</h3>
                        <p class="text-gray-600 leading-relaxed">
                            Whether it's working on a puzzle, tending the garden, reading together, or listening to music, we engage in activities that bring you joy and spark connection.
                        </p>
                    </div>

                    <div class="relative pl-8 border-l-2 border-green-dark/20">
                        <div class="absolute -left-3 top-0 w-5 h-5 rounded-full bg-green-dark"></div>
                        <h3 class="text-2xl font-bold text-gray-900 mb-3">Getting Out & About</h3>
                        <p class="text-gray-600 leading-relaxed">
                            A gentle walk in the park, a visit to the local café, or a stroll through the shops - whatever helps you stay connected to your community.
                        </p>
                    </div>

                    <div class="relative pl-8">
                        <div class="absolute -left-3 top-0 w-5 h-5 rounded-full bg-green-dark"></div>
                        <h3 class="text-2xl font-bold text-gray-900 mb-3">Simply Being Present</h3>
                        <p class="text-gray-600 leading-relaxed">
                            Sometimes the most valuable thing is just being there - a friendly face, a listening ear, and the comfort of knowing you're not alone.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Why It Matters Section -->
    <section class="py-20 md:py-28 bg-warm-50">
        <div class="max-w-4xl mx-auto px-6">
            <div class="text-center mb-16">
                <p class="text-green-dark text-sm font-medium tracking-[0.2em] uppercase mb-4">The Impact</p>
                <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
                    Why Companionship Matters
                </h2>
            </div>

            <div class="space-y-6">
                <div class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-md transition-shadow">
                    <p class="text-gray-700 text-lg leading-relaxed italic">
                        "Loneliness and social isolation can be as harmful to health as smoking 15 cigarettes a day. Regular social connection isn't just nice to have - it's essential for wellbeing."
                    </p>
                </div>

                <div class="grid md:grid-cols-3 gap-6">
                    <div class="bg-white rounded-xl p-6 text-center">
                        <div class="text-4xl font-bold text-green-dark mb-2">76%</div>
                        <p class="text-gray-600">report improved mood with regular companionship</p>
                    </div>
                    <div class="bg-white rounded-xl p-6 text-center">
                        <div class="text-4xl font-bold text-green-dark mb-2">68%</div>
                        <p class="text-gray-600">feel more connected to their community</p>
                    </div>
                    <div class="bg-white rounded-xl p-6 text-center">
                        <div class="text-4xl font-bold text-green-dark mb-2">82%</div>
                        <p class="text-gray-600">experience reduced feelings of isolation</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <CallToAction />
    <Footer />
</Layout>
