---
import { getEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CallToAction from '../../components/CallToAction.astro';
import OnThisPage from '../../components/OnThisPage.astro';
import BackToTop from '../../components/BackToTop.astro';
import personalAssistantImage from "../../assets/personal-assistant.jpg";
import * as ServiceComponent from "../../components/Services";
import SectionDivider from '../../components/SectionDivider.astro';

const entry = await getEntry('services', 'personal-assistants');
if (!entry) throw new Error('Service content not found: personal-assistants');
const { meta, hero, about, testimonials, testimonialsBackground } = entry.data;

const onThisPageItems = [
    { id: 'about', label: about.subTitle },
    ...(entry.data.story ? [{ id: 'story', label: "A Loved One's Experience" }] : []),
    { id: 'testimonials', label: 'Testimonials' },
    { id: 'contact', label: "We're Here to Help" },
];
---

<Layout title={meta.title} description={meta.description}>
    <Navbar/>

    <main>
        <ServiceComponent.ServicesHero
                label={hero.label}
                title={hero.title}
                description={hero.description}
                image={personalAssistantImage}
                imageAlt={hero.imageAlt}
        />

        <OnThisPage items={onThisPageItems} />

        <SectionDivider />

        <ServiceComponent.ServicesAbout
                title={about.title}
                subTitle={about.subTitle}
                sections={about.sections}
                callout={about.callout}
        />

        <SectionDivider />

        <ServiceComponent.ServicesTestimonials id="testimonials" testimonials={testimonials} background={testimonialsBackground}/>

        <SectionDivider />

        <CallToAction id="contact" />
    </main>

    <BackToTop />
    <Footer/>
</Layout>
