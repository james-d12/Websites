---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CallToAction from '../../components/CallToAction.astro';
import Hero from '../../components/Services/Hero.astro';
import Testimonials from '../../components/Services/Testimonials.astro';
import personalAssistantImage from "../../assets/tatiana-zanon-MMhazsT2wtM-unsplash.jpg";

const testimonials = [
    {
        quote: "My personal assistant has transformed how I manage my life. From organizing appointments to handling correspondence, I finally feel in control again instead of overwhelmed.",
        name: "David P.",
        relationship: "Client",
        service: "Personal Assistant"
    },
    {
        quote: "After my stroke, managing paperwork and admin became impossible. Having someone I trust to handle these details has given me back my independence and peace of mind.",
        name: "Patricia K.",
        relationship: "Client",
        service: "Personal Assistant"
    },
    {
        quote: "They don't just do tasks - they genuinely understand what I need and work the way I work. It's like having a partner who keeps my life running smoothly.",
        name: "James R.",
        relationship: "Client",
        service: "Personal Assistant"
    }
];
---

<Layout title="Personal Assistant Services - St Catherine's Group"
        description="Unrivalled one-to-one personal assistance, built on discretion, sophistication, and seamless organisation for those who expect the very best.">
    <Navbar/>

    <main>
        <Hero
                label="Our Services"
                title="Personal Assistant"
                description="Unrivalled one-to-one personal assistance for those who value discretion, sophistication, and seamless organisation. Every aspect of daily life handled with impeccable care, giving you and your family complete reassurance and peace of mind."
                image={personalAssistantImage}
                imageAlt="Personal assistant services"
        />

        <section class="py-24 md:py-32 bg-white">
            <div class="max-w-5xl mx-auto px-6">
                <div class="text-center mb-16">
                    <p class="text-green-dark text-xl font-medium tracking-[0.2em] uppercase mb-4">About the Service</p>
                    <h2 class="text-5xl md:text-6xl font-bold text-gray-900">Personal Assistant</h2>
                </div>

                <div class="space-y-12">
                    <div>
                        <div class="flex gap-4 items-center mb-4">
                            <div class="shrink-0 w-12 h-12 rounded-xl bg-green-dark/10 flex items-center justify-center">
                                <svg class="w-6 h-6 text-green-dark" fill="none" stroke="currentColor"
                                     viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                          d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                                </svg>
                            </div>
                            <h3 class="text-3xl font-bold text-gray-900">Discretion, Sophistication & Seamless
                                Organisation</h3>
                        </div>
                        <p class="text-2xl leading-relaxed text-gray-600 pl-16">At St Catherine's, we offer an
                            unrivalled level of one-to-one personal assistance support for individuals living in their
                            own homes as well as for residents within high-end residences. Designed for those who value
                            discretion, sophistication, and seamless organisation, our Personal Assistants provide a
                            personalised experience that enhances every aspect of daily life while offering families
                            complete reassurance and peace of mind.</p>
                    </div>

                    <div>
                        <div class="flex gap-4 items-center mb-4">
                            <div class="shrink-0 w-12 h-12 rounded-xl bg-green-dark/10 flex items-center justify-center">
                                <svg class="w-6 h-6 text-green-dark" fill="none" stroke="currentColor"
                                     viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                          d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
                                </svg>
                            </div>
                            <h3 class="text-3xl font-bold text-gray-900">Dedicated to Your Lifestyle & Preferences</h3>
                        </div>
                        <p class="text-2xl leading-relaxed text-gray-600 pl-16">Each Personal Assistant provided by St
                            Catherine's is carefully selected for their professionalism, discretion, and exceptional
                            attention to detail. They are dedicated exclusively to understanding the client's lifestyle,
                            preferences, and routines. From managing diaries, appointments, and correspondence to
                            coordinating social engagements, travel, family visits, and shopping, every task is handled
                            with impeccable precision and care, ensuring the experience is effortless and enjoyable.</p>
                    </div>

                    <div>
                        <div class="flex gap-4 items-center mb-4">
                            <div class="shrink-0 w-12 h-12 rounded-xl bg-green-dark/10 flex items-center justify-center">
                                <svg class="w-6 h-6 text-green-dark" fill="none" stroke="currentColor"
                                     viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                          d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                                </svg>
                            </div>
                            <h3 class="text-3xl font-bold text-gray-900">A Trusted Point of Contact for Families</h3>
                        </div>
                        <p class="text-2xl leading-relaxed text-gray-600 pl-16">For families, St Catherine's Personal
                            Assistants serve as a trusted and consistent point of contact, liaising seamlessly with
                            household staff, external service providers, and where relevant, residential teams. This
                            ensures that communication is clear, coordination is smooth, and the client's preferences,
                            wishes, and wellbeing are always prioritised.</p>
                    </div>

                    <div>
                        <div class="flex gap-4 items-center mb-4">
                            <div class="shrink-0 w-12 h-12 rounded-xl bg-green-dark/10 flex items-center justify-center">
                                <svg class="w-6 h-6 text-green-dark" fill="none" stroke="currentColor"
                                     viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                          d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                                </svg>
                            </div>
                            <h3 class="text-3xl font-bold text-gray-900">Companionship, Advocacy & Lifestyle
                                Management</h3>
                        </div>
                        <p class="text-2xl leading-relaxed text-gray-600 pl-16">Beyond organisation, the service offers
                            companionship, advocacy, and lifestyle management. St Catherine's Personal Assistants
                            anticipate needs, curate experiences, and ensure that every day flows smoothly and
                            elegantly. For clients in high-end residences, the role complements any regulated support
                            provided by staff, while for private home clients, the focus is entirely on enhancing
                            comfort, convenience, and independence.</p>
                    </div>
                </div>

                <div>
                    <div class="flex gap-4 items-center mb-4">
                        <div class="shrink-0 w-12 h-12 rounded-xl bg-green-dark/10 flex items-center justify-center">
                            <svg class="w-6 h-6 text-green-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                      d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                            </svg>
                        </div>
                        <h3 class="text-3xl font-bold text-gray-900">The Right Match, Every Time</h3>
                    </div>
                    <p class="text-2xl leading-relaxed text-gray-600 pl-16">We recognise the relationship between a
                        client and their Personal Assistant is highly personal. If the match does not feel quite right,
                        we work closely with the client and their family to ensure a replacement is provided who meets
                        their exact requirements. Our priority is always to create a harmonious and supportive
                        partnership that enhances daily life.</p>
                </div>

                <div class="mt-16 bg-green-dark rounded-2xl p-8 md:p-10 flex items-start gap-6">
                    <div class="shrink-0 w-12 h-12 rounded-xl bg-white/20 flex items-center justify-center mt-1">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                  d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>
                        </svg>
                    </div>
                    <div>
                        <p class="text-white/70 text-sm font-medium tracking-[0.2em] uppercase mb-2">Entirely
                            Bespoke</p>
                        <p class="text-white text-2xl leading-relaxed font-medium">Above all, the Personal Assistant
                            service from St Catherine's is entirely bespoke. Every aspect is tailored to the individual,
                            their family, and their lifestyle.</p>
                    </div>
                </div>
            </div>
        </section>

        <Testimonials testimonials={testimonials}/>

        <CallToAction background="bg-white"/>
    </main>

    <Footer/>
</Layout>
