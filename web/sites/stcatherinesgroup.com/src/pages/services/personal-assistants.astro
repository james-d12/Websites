---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CallToAction from '../../components/CallToAction.astro';
import Hero from '../../components/Services/Hero.astro';
import Testimonials from '../../components/Services/Testimonials.astro';
import personalAssistantImage from "../../assets/tatiana-zanon-MMhazsT2wtM-unsplash.jpg";

const testimonials = [
    {
        quote: "My personal assistant has transformed how I manage my life. From organizing appointments to handling correspondence, I finally feel in control again instead of overwhelmed.",
        name: "David P.",
        relationship: "Client",
        service: "Personal Assistant"
    },
    {
        quote: "After my stroke, managing paperwork and admin became impossible. Having someone I trust to handle these details has given me back my independence and peace of mind.",
        name: "Patricia K.",
        relationship: "Client",
        service: "Personal Assistant"
    },
    {
        quote: "They don't just do tasks - they genuinely understand what I need and work the way I work. It's like having a partner who keeps my life running smoothly.",
        name: "James R.",
        relationship: "Client",
        service: "Personal Assistant"
    }
];
---

<Layout title="Personal Assistant Services - St Catherine's Group"
        description="Practical, day-to-day assistance to help you manage life on your own terms with confidence.">
    <Navbar/>

    <main>
        <Hero
                label="Our Services"
                title="Personal Assistant"
                description="Practical, day-to-day assistance to help you manage life on your own terms with confidence. From organizing appointments and managing correspondence to helping with household tasks and personal admin, we handle the details so you can focus on what matters most to you."
                image={personalAssistantImage}
                imageAlt="Personal assistant services"
        />

        <section class="py-20 md:py-28 bg-white">
            <div class="max-w-6xl mx-auto px-6">
                <div class="text-center mb-16">
                    <p class="text-green-dark text-sm font-medium tracking-[0.2em] uppercase mb-4">We Handle The
                        Details</p>
                    <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
                        Life Admin, Simplified
                    </h2>
                    <p class="text-gray-600 text-lg leading-relaxed max-w-3xl mx-auto">
                        From managing your calendar to organizing your home, we take care of the administrative tasks
                        that
                        consume your time and energy.
                    </p>
                </div>

                <div class="grid md:grid-cols-3 gap-6">
                    <div class="space-y-6">
                        <div class="bg-warm-50 rounded-xl p-6">
                            <div class="flex items-center gap-3 mb-4">
                                <div class="w-10 h-10 rounded-lg bg-green-dark flex items-center justify-center">
                                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor"
                                         viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                    </svg>
                                </div>
                                <h3 class="text-lg font-bold text-gray-900">Calendar & Scheduling</h3>
                            </div>
                            <ul class="space-y-2 text-gray-600 text-sm">
                                <li class="flex items-start gap-2">
                                    <span class="text-green-dark">→</span>
                                    <span>Book and manage appointments</span>
                                </li>
                                <li class="flex items-start gap-2">
                                    <span class="text-green-dark">→</span>
                                    <span>Set reminders for important dates</span>
                                </li>
                                <li class="flex items-start gap-2">
                                    <span class="text-green-dark">→</span>
                                    <span>Coordinate multiple commitments</span>
                                </li>
                            </ul>
                        </div>

                        <div class="bg-warm-50 rounded-xl p-6">
                            <div class="flex items-center gap-3 mb-4">
                                <div class="w-10 h-10 rounded-lg bg-green-dark flex items-center justify-center">
                                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor"
                                         viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                                    </svg>
                                </div>
                                <h3 class="text-lg font-bold text-gray-900">Mail & Communication</h3>
                            </div>
                            <ul class="space-y-2 text-gray-600 text-sm">
                                <li class="flex items-start gap-2">
                                    <span class="text-green-dark">→</span>
                                    <span>Sort and organize correspondence</span>
                                </li>
                                <li class="flex items-start gap-2">
                                    <span class="text-green-dark">→</span>
                                    <span>Draft letters and emails</span>
                                </li>
                                <li class="flex items-start gap-2">
                                    <span class="text-green-dark">→</span>
                                    <span>Make calls on your behalf</span>
                                </li>
                            </ul>
                        </div>
                    </div>

                    <div class="space-y-6">
                        <div class="bg-warm-50 rounded-xl p-6">
                            <div class="flex items-center gap-3 mb-4">
                                <div class="w-10 h-10 rounded-lg bg-green-dark flex items-center justify-center">
                                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor"
                                         viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
                                    </svg>
                                </div>
                                <h3 class="text-lg font-bold text-gray-900">Paperwork & Forms</h3>
                            </div>
                            <ul class="space-y-2 text-gray-600 text-sm">
                                <li class="flex items-start gap-2">
                                    <span class="text-green-dark">→</span>
                                    <span>Complete forms accurately</span>
                                </li>
                                <li class="flex items-start gap-2">
                                    <span class="text-green-dark">→</span>
                                    <span>Organize important documents</span>
                                </li>
                                <li class="flex items-start gap-2">
                                    <span class="text-green-dark">→</span>
                                    <span>File and retrieve records</span>
                                </li>
                            </ul>
                        </div>

                        <div class="bg-warm-50 rounded-xl p-6">
                            <div class="flex items-center gap-3 mb-4">
                                <div class="w-10 h-10 rounded-lg bg-green-dark flex items-center justify-center">
                                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor"
                                         viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
                                    </svg>
                                </div>
                                <h3 class="text-lg font-bold text-gray-900">Financial Tasks</h3>
                            </div>
                            <ul class="space-y-2 text-gray-600 text-sm">
                                <li class="flex items-start gap-2">
                                    <span class="text-green-dark">→</span>
                                    <span>Pay bills and track expenses</span>
                                </li>
                                <li class="flex items-start gap-2">
                                    <span class="text-green-dark">→</span>
                                    <span>Manage budgets and statements</span>
                                </li>
                                <li class="flex items-start gap-2">
                                    <span class="text-green-dark">→</span>
                                    <span>Liaise with banks and providers</span>
                                </li>
                            </ul>
                        </div>
                    </div>

                    <div class="space-y-6">
                        <div class="bg-warm-50 rounded-xl p-6">
                            <div class="flex items-center gap-3 mb-4">
                                <div class="w-10 h-10 rounded-lg bg-green-dark flex items-center justify-center">
                                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor"
                                         viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                                    </svg>
                                </div>
                                <h3 class="text-lg font-bold text-gray-900">Home Organization</h3>
                            </div>
                            <ul class="space-y-2 text-gray-600 text-sm">
                                <li class="flex items-start gap-2">
                                    <span class="text-green-dark">→</span>
                                    <span>Declutter and organize spaces</span>
                                </li>
                                <li class="flex items-start gap-2">
                                    <span class="text-green-dark">→</span>
                                    <span>Create filing systems</span>
                                </li>
                                <li class="flex items-start gap-2">
                                    <span class="text-green-dark">→</span>
                                    <span>Coordinate tradespeople</span>
                                </li>
                            </ul>
                        </div>

                        <div class="bg-warm-50 rounded-xl p-6">
                            <div class="flex items-center gap-3 mb-4">
                                <div class="w-10 h-10 rounded-lg bg-green-dark flex items-center justify-center">
                                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor"
                                         viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/>
                                    </svg>
                                </div>
                                <h3 class="text-lg font-bold text-gray-900">Special Projects</h3>
                            </div>
                            <ul class="space-y-2 text-gray-600 text-sm">
                                <li class="flex items-start gap-2">
                                    <span class="text-green-dark">→</span>
                                    <span>Research and planning</span>
                                </li>
                                <li class="flex items-start gap-2">
                                    <span class="text-green-dark">→</span>
                                    <span>Event coordination</span>
                                </li>
                                <li class="flex items-start gap-2">
                                    <span class="text-green-dark">→</span>
                                    <span>Custom requests welcome</span>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="py-20 md:py-28 bg-warm-50">
            <div class="max-w-6xl mx-auto px-6">
                <div class="grid lg:grid-cols-5 gap-12 items-center">
                    <div class="lg:col-span-2">
                        <p class="text-green-dark text-sm font-medium tracking-[0.2em] uppercase mb-4">Time Well
                            Spent</p>
                        <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
                            Get Your Time Back
                        </h2>
                        <p class="text-gray-600 text-lg leading-relaxed mb-8">
                            When we handle the administrative burden, you're free to focus on what truly matters -
                            family,
                            hobbies, health, and the activities that bring you joy and fulfillment.
                        </p>
                        <div class="bg-white rounded-xl p-6 shadow-sm">
                            <p class="text-gray-700 leading-relaxed italic">
                                "The average person spends 8-12 hours per week on household admin and organization.
                                Imagine
                                having that time back to spend on the things you love."
                            </p>
                        </div>
                    </div>

                    <div class="lg:col-span-3 space-y-4">
                        <div class="flex items-center gap-4 bg-white rounded-xl p-6 shadow-sm">
                            <div class="shrink-0 w-16 h-16 rounded-full bg-green-dark/10 flex items-center justify-center">
                                <span class="text-3xl font-bold text-green-dark">1</span>
                            </div>
                            <div>
                                <h3 class="text-xl font-bold text-gray-900 mb-1">Tell Us What You Need</h3>
                                <p class="text-gray-600">We discuss your priorities, challenges, and the tasks you'd
                                    like
                                    support with</p>
                            </div>
                        </div>

                        <div class="flex items-center gap-4 bg-white rounded-xl p-6 shadow-sm">
                            <div class="shrink-0 w-16 h-16 rounded-full bg-green-dark/10 flex items-center justify-center">
                                <span class="text-3xl font-bold text-green-dark">2</span>
                            </div>
                            <div>
                                <h3 class="text-xl font-bold text-gray-900 mb-1">We Create Your System</h3>
                                <p class="text-gray-600">Together we establish routines, preferences, and processes that
                                    work for you</p>
                            </div>
                        </div>

                        <div class="flex items-center gap-4 bg-white rounded-xl p-6 shadow-sm">
                            <div class="shrink-0 w-16 h-16 rounded-full bg-green-dark/10 flex items-center justify-center">
                                <span class="text-3xl font-bold text-green-dark">3</span>
                            </div>
                            <div>
                                <h3 class="text-xl font-bold text-gray-900 mb-1">You Stay In Control</h3>
                                <p class="text-gray-600">Final decisions are always yours - we simply handle the details
                                    and
                                    keep you informed</p>
                            </div>
                        </div>

                        <div class="flex items-center gap-4 bg-white rounded-xl p-6 shadow-sm">
                            <div class="shrink-0 w-16 h-16 rounded-full bg-green-dark/10 flex items-center justify-center">
                                <span class="text-3xl font-bold text-green-dark">4</span>
                            </div>
                            <div>
                                <h3 class="text-xl font-bold text-gray-900 mb-1">Life Gets Easier</h3>
                                <p class="text-gray-600">Reduce stress, stay organized, and enjoy the freedom of having
                                    support you can trust</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <Testimonials testimonials={testimonials}/>
    </main>

    <CallToAction/>
    <Footer/>
</Layout>
