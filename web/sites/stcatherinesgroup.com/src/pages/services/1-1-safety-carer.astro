---
import { getEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CallToAction from '../../components/CallToAction.astro';
import safetyImage from "../../assets/safety-carer.jpg";
import * as ServiceComponent from "../../components/Services";
import SectionDivider from '../../components/SectionDivider.astro';

const entry = await getEntry('services', '1-1-safety-carer');
if (!entry) throw new Error('Service content not found: 1-1-safety-carer');
const { meta, hero, about, testimonials, testimonialsBackground } = entry.data;
---

<Layout title={meta.title} description={meta.description}>
    <Navbar/>

    <main>
        <ServiceComponent.ServicesHero
                label={hero.label}
                title={hero.title}
                description={hero.description}
                image={safetyImage}
                imageAlt={hero.imageAlt}
        />

        <SectionDivider />

        <ServiceComponent.ServicesAbout
                title={about.title}
                subTitle={about.subTitle}
                sections={about.sections}
                callout={about.callout}
        />

        <SectionDivider />

        <ServiceComponent.ServicesStory entry={entry}/>

        <SectionDivider />

        <ServiceComponent.ServicesTestimonials testimonials={testimonials} background={testimonialsBackground}/>

        <SectionDivider />

        <CallToAction />
    </main>

    <Footer/>
</Layout>
