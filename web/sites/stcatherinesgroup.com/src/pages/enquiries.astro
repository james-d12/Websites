---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Enquiries - St Catherine's Group" description="Get in touch with St Catherine's Group for client services or career opportunities.">
    <Navbar />

    <!-- Hero Section -->
    <section class="relative bg-gradient-to-b from-white to-warm-50 py-20 md:py-28">
        <div class="max-w-4xl mx-auto px-6 text-center">
            <p class="text-green-dark text-sm font-medium tracking-[0.2em] uppercase mb-4">
                Get In Touch
            </p>
            <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-gray-900 mb-6">
                Enquiries
            </h1>
            <p class="text-gray-600 text-xl md:text-2xl leading-relaxed">
                Whether you're looking for care services or interested in joining our team, we'd love to hear from you.
            </p>
        </div>
    </section>

    <!-- Two Column Section -->
    <section class="py-20 md:py-28 bg-white">
        <div class="max-w-7xl mx-auto px-6">
            <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">

                <!-- Client Enquiries -->
                <div class="bg-warm-50 rounded-2xl p-8 md:p-10">
                    <div class="mb-8">
                        <div class="w-16 h-16 rounded-xl bg-green-dark flex items-center justify-center mb-6">
                            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                            </svg>
                        </div>
                        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
                            Client Services
                        </h2>
                        <p class="text-gray-700 text-lg leading-relaxed mb-6">
                            Looking for care support for yourself or a loved one? We're here to discuss your needs and how we can help.
                        </p>
                    </div>

                    <div class="space-y-6">
                        <div class="flex items-start gap-4">
                            <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-white flex items-center justify-center">
                                <svg class="w-6 h-6 text-green-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-lg font-semibold text-gray-900 mb-1">Call Us</h3>
                                <a href="tel:+442036633074" class="text-gray-600 hover:text-green-dark transition-colors block">
                                    Landline: 020 3663 3074
                                </a>
                                <a href="tel:+447780149826" class="text-gray-600 hover:text-green-dark transition-colors block">
                                    Mobile: 07780 149826
                                </a>
                            </div>
                        </div>

                        <div class="flex items-start gap-4">
                            <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-white flex items-center justify-center">
                                <svg class="w-6 h-6 text-green-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-lg font-semibold text-gray-900 mb-1">Email</h3>
                                <a href="mailto:clientservices@stcatherinesgroup.com" class="text-gray-600 hover:text-green-dark transition-colors">
                                    clientservices@stcatherinesgroup.com
                                </a>
                            </div>
                        </div>

                        <div class="pt-6">
                            <a
                                href="/contact"
                                class="inline-flex items-center justify-center w-full px-8 py-4 bg-green-dark text-white font-semibold text-lg rounded-lg hover:bg-green-dark/90 transition-all duration-200 shadow-md"
                            >
                                Contact Us About Care
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Career Enquiries -->
                <div class="bg-warm-50 rounded-2xl p-8 md:p-10">
                    <div class="mb-8">
                        <div class="w-16 h-16 rounded-xl bg-green-dark flex items-center justify-center mb-6">
                            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                            </svg>
                        </div>
                        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
                            Join Our Team
                        </h2>
                        <p class="text-gray-700 text-lg leading-relaxed mb-6">
                            Interested in a rewarding career in care? We're always looking for compassionate, dedicated professionals to join St Catherine's Group.
                        </p>
                    </div>

                    <div class="space-y-6">
                        <div class="bg-white rounded-xl p-6">
                            <h3 class="text-xl font-bold text-gray-900 mb-3">Current Opportunities</h3>
                            <ul class="space-y-3 text-gray-700">
                                <li class="flex items-start gap-2">
                                    <span class="text-green-dark mt-1">•</span>
                                    <span>Care Assistants (1-1 Carer Services)</span>
                                </li>
                                <li class="flex items-start gap-2">
                                    <span class="text-green-dark mt-1">•</span>
                                    <span>Registered Nurses (All Specialties)</span>
                                </li>
                                <li class="flex items-start gap-2">
                                    <span class="text-green-dark mt-1">•</span>
                                    <span>Dementia Care Specialists</span>
                                </li>
                                <li class="flex items-start gap-2">
                                    <span class="text-green-dark mt-1">•</span>
                                    <span>Personal Assistants</span>
                                </li>
                            </ul>
                        </div>

                        <div class="flex items-start gap-4">
                            <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-white flex items-center justify-center">
                                <svg class="w-6 h-6 text-green-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-lg font-semibold text-gray-900 mb-1">Apply Now</h3>
                                <a href="mailto:careers@stcatherinesgroup.com" class="text-gray-600 hover:text-green-dark transition-colors">
                                    careers@stcatherinesgroup.com
                                </a>
                            </div>
                        </div>

                        <div class="bg-green-dark/5 rounded-lg p-4">
                            <p class="text-sm text-gray-700">
                                <strong>We offer:</strong> Competitive pay, flexible hours, full training, career development, and the opportunity to make a real difference in people's lives.
                            </p>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <!-- Additional Info Section -->
    <section class="py-20 md:py-28 bg-warm-50">
        <div class="max-w-4xl mx-auto px-6 text-center">
            <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
                We're Here to Help
            </h2>
            <p class="text-gray-700 text-xl leading-relaxed mb-8">
                Whether you have questions about our services, need care advice, or want to explore career opportunities, don't hesitate to reach out. We respond to all enquiries promptly and are always happy to have a conversation.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a
                    href="tel:+442036633074"
                    class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-green-dark text-white font-medium text-lg rounded-lg hover:bg-green-dark/90 transition-all duration-200 shadow-md"
                >
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                    </svg>
                    020 3663 3074
                </a>
                <a
                    href="tel:+447780149826"
                    class="inline-flex items-center justify-center gap-3 px-8 py-4 border-2 border-green-dark text-green-dark font-medium text-lg rounded-lg hover:bg-green-dark hover:text-white transition-all duration-200"
                >
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
                    </svg>
                    07780 149826
                </a>
            </div>
        </div>
    </section>

    <Footer />
</Layout>
