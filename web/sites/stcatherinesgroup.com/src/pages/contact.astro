---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact Us - St Catherine's Group" description="Get in touch with St Catherine's Group. We're here to answer your questions and discuss how we can support you.">
    <Navbar />

    <!-- Hero Section -->
    <section class="relative bg-gradient-to-b from-white to-warm-50 py-20 md:py-28">
        <div class="max-w-4xl mx-auto px-6 text-center">
            <p class="text-green-dark text-sm font-medium tracking-[0.2em] uppercase mb-4">
                Get In Touch
            </p>
            <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-gray-900 mb-6">
                Contact Us
            </h1>
            <p class="text-gray-600 text-xl md:text-2xl leading-relaxed">
                We're here to listen, answer your questions, and discuss how we can best support you or your loved ones.
            </p>
        </div>
    </section>

    <!-- Contact Section -->
    <section class="py-20 md:py-28 bg-white">
        <div class="max-w-6xl mx-auto px-6">
            <div class="grid lg:grid-cols-5 gap-12">

                <!-- Contact Information -->
                <div class="lg:col-span-2 space-y-8">
                    <div>
                        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
                            Let's Talk
                        </h2>
                        <p class="text-gray-600 text-lg leading-relaxed mb-8">
                            Whether you're looking for support for yourself or someone you care about, we're ready to help. Reach out today for a friendly, no-obligation conversation.
                        </p>
                    </div>

                    <!-- Contact Details -->
                    <div class="space-y-6">
                        <div class="flex items-start gap-4">
                            <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-green-dark/10 flex items-center justify-center">
                                <svg class="w-6 h-6 text-green-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-lg font-semibold text-gray-900 mb-1">Landline</h3>
                                <a href="tel:+442036633074" class="text-gray-600 hover:text-green-dark transition-colors">
                                    020 3663 3074
                                </a>
                            </div>
                        </div>

                        <div class="flex items-start gap-4">
                            <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-green-dark/10 flex items-center justify-center">
                                <svg class="w-6 h-6 text-green-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-lg font-semibold text-gray-900 mb-1">Mobile</h3>
                                <a href="tel:+447780149826" class="text-gray-600 hover:text-green-dark transition-colors">
                                    07780 149826
                                </a>
                            </div>
                        </div>

                        <div class="flex items-start gap-4">
                            <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-green-dark/10 flex items-center justify-center">
                                <svg class="w-6 h-6 text-green-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-lg font-semibold text-gray-900 mb-1">Email</h3>
                                <a href="mailto:clientservices@stcatherinesgroup.com" class="text-gray-600 hover:text-green-dark transition-colors">
                                    clientservices@stcatherinesgroup.com
                                </a>
                            </div>
                        </div>

                        <div class="flex items-start gap-4">
                            <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-green-dark/10 flex items-center justify-center">
                                <svg class="w-6 h-6 text-green-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-lg font-semibold text-gray-900 mb-1">Address</h3>
                                <p class="text-gray-600">
                                    123 Healthcare Lane<br>
                                    Your Town<br>
                                    Postcode AB12 3CD
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Emergency Notice -->
                    <div class="bg-warm-50 rounded-xl p-6 border-l-4 border-green-dark">
                        <p class="text-sm text-gray-700">
                            <strong class="text-gray-900">Need immediate support?</strong><br>
                            Our care services are available 24/7. Call us anytime on the number above.
                        </p>
                    </div>
                </div>

                <!-- Contact Form -->
                <div class="lg:col-span-3">
                    <div class="bg-warm-50 rounded-2xl p-8 md:p-10">
                        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6">
                            Send Us a Message
                        </h2>

                        <form class="space-y-6" id="contact-form">
                            <div class="grid md:grid-cols-2 gap-6">
                                <div>
                                    <label for="first-name" class="block text-sm font-medium text-gray-700 mb-2">
                                        First Name *
                                    </label>
                                    <input
                                        type="text"
                                        id="first-name"
                                        name="first-name"
                                        required
                                        class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-green-dark focus:border-transparent outline-none transition-all"
                                        placeholder="John"
                                    />
                                </div>
                                <div>
                                    <label for="last-name" class="block text-sm font-medium text-gray-700 mb-2">
                                        Last Name *
                                    </label>
                                    <input
                                        type="text"
                                        id="last-name"
                                        name="last-name"
                                        required
                                        class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-green-dark focus:border-transparent outline-none transition-all"
                                        placeholder="Smith"
                                    />
                                </div>
                            </div>

                            <div class="grid md:grid-cols-2 gap-6">
                                <div>
                                    <label for="email" class="block text-sm font-medium text-gray-700 mb-2">
                                        Email Address *
                                    </label>
                                    <input
                                        type="email"
                                        id="email"
                                        name="email"
                                        required
                                        class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-green-dark focus:border-transparent outline-none transition-all"
                                        placeholder="john.smith@example.com"
                                    />
                                </div>
                                <div>
                                    <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">
                                        Phone Number
                                    </label>
                                    <input
                                        type="tel"
                                        id="phone"
                                        name="phone"
                                        class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-green-dark focus:border-transparent outline-none transition-all"
                                        placeholder="01234 567890"
                                    />
                                </div>
                            </div>

                            <div>
                                <label for="service" class="block text-sm font-medium text-gray-700 mb-2">
                                    Service Interested In
                                </label>
                                <select
                                    id="service"
                                    name="service"
                                    class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-green-dark focus:border-transparent outline-none transition-all"
                                >
                                    <option value="">Please select...</option>
                                    <option value="companionship">Companionship</option>
                                    <option value="chaperone">Chaperone</option>
                                    <option value="dementia">Dementia Care</option>
                                    <option value="1-1-safety">1-1 Safety</option>
                                    <option value="personal-assistant">Personal Assistant</option>
                                    <option value="general">General Enquiry</option>
                                </select>
                            </div>

                            <div>
                                <label for="message" class="block text-sm font-medium text-gray-700 mb-2">
                                    Your Message *
                                </label>
                                <textarea
                                    id="message"
                                    name="message"
                                    required
                                    rows="6"
                                    class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-green-dark focus:border-transparent outline-none transition-all resize-none"
                                    placeholder="Tell us a bit about what you're looking for..."
                                ></textarea>
                            </div>

                            <div class="flex items-start gap-3">
                                <input
                                    type="checkbox"
                                    id="privacy"
                                    name="privacy"
                                    required
                                    class="mt-1 w-4 h-4 text-green-dark border-gray-300 rounded focus:ring-green-dark"
                                />
                                <label for="privacy" class="text-sm text-gray-600">
                                    I agree to the privacy policy and consent to St Catherine's Group contacting me regarding my enquiry. *
                                </label>
                            </div>

                            <button
                                type="submit"
                                class="w-full md:w-auto px-8 py-4 bg-green-dark text-white font-semibold text-lg rounded-lg hover:bg-green-dark/90 transition-all duration-200 shadow-md hover:shadow-lg"
                            >
                                Send Message
                            </button>
                        </form>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <Footer />
</Layout>

<script>
    // Basic form handling (you'll want to connect this to your actual backend)
    document.addEventListener('DOMContentLoaded', () => {
        const form = document.getElementById('contact-form');

        if (form) {
            form.addEventListener('submit', (e) => {
                e.preventDefault();

                // Get form data
                const formData = new FormData(form);
                const data = Object.fromEntries(formData);

                // Here you would typically send this to your backend
                console.log('Form submitted:', data);

                // Show success message (you'll want to make this nicer)
                alert('Thank you for your message! We will get back to you as soon as possible.');

                // Reset form
                form.reset();
            });
        }
    });
</script>
