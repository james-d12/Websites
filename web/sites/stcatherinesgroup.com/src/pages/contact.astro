---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact Us - St Catherine's Group"
        description="Get in touch with St Catherine's Group. We're here to answer your questions and discuss how we can support you.">
    <Navbar/>

    <main>
        <section class="relative bg-linear-to-b from-white to-warm-50 py-16 md:py-20">
            <div class="max-w-3xl mx-auto px-6 text-center">
                <p class="text-green-dark text-sm font-medium tracking-[0.2em] uppercase mb-4">
                    Get In Touch
                </p>
                <h1 class="text-5xl md:text-6xl font-bold text-gray-900 mb-5">
                    Contact Us
                </h1>
                <p class="text-gray-600 text-xl leading-relaxed">
                    We're here to listen, answer your questions, and discuss how we can best support you or your loved ones.
                </p>
            </div>
        </section>

        <section class="py-4 bg-green-dark">
            <div class="max-w-3xl mx-auto px-6 py-5 flex flex-col sm:flex-row items-center justify-between gap-4">
                <div class="text-center sm:text-left">
                    <p class="text-white font-semibold text-lg">Need immediate support?</p>
                    <p class="text-green-dark/30 text-white/70 text-sm mt-0.5">Our care services are available 24/7 — call us anytime.</p>
                </div>
                <a href="tel:+442036633074"
                   class="shrink-0 bg-white text-green-dark font-semibold px-6 py-3 rounded-lg hover:bg-warm-50 transition-colors text-lg">
                    020 3663 3074
                </a>
            </div>
        </section>

        <section class="py-20 md:py-28 bg-warm-50">
            <div class="max-w-3xl mx-auto px-6">
                <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-12 text-center">
                    Ways to Reach Us
                </h2>

                <div class="space-y-4">
                    <div class="bg-white rounded-xl p-7 flex flex-col sm:flex-row sm:items-center gap-6">
                        <div class="shrink-0 w-14 h-14 rounded-xl bg-green-dark/10 flex items-center justify-center">
                            <svg class="w-7 h-7 text-green-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                            </svg>
                        </div>
                        <div class="flex-1">
                            <p class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-2">Call Us</p>
                            <div class="flex flex-col sm:flex-row gap-3">
                                <a href="tel:+442036633074"
                                   class="text-xl font-semibold text-gray-900 hover:text-green-dark transition-colors">
                                    020 3663 3074
                                    <span class="text-sm font-normal text-gray-400 ml-1">Landline</span>
                                </a>
                                <span class="hidden sm:inline text-gray-300">·</span>
                                <a href="tel:+447780149826"
                                   class="text-xl font-semibold text-gray-900 hover:text-green-dark transition-colors">
                                    07780 149826
                                    <span class="text-sm font-normal text-gray-400 ml-1">Mobile</span>
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="bg-white rounded-xl p-7 flex flex-col sm:flex-row sm:items-center gap-6">
                        <div class="shrink-0 w-14 h-14 rounded-xl bg-green-dark/10 flex items-center justify-center">
                            <svg class="w-7 h-7 text-green-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                            </svg>
                        </div>
                        <div class="flex-1">
                            <p class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-2">Email Us</p>
                            <a href="mailto:clientservices@stcatherinesgroup.com"
                               class="text-xl font-semibold text-gray-900 hover:text-green-dark transition-colors break-all">
                                clientservices@stcatherinesgroup.com
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <Footer/>
</Layout>
