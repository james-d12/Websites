---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact Us - St Catherine's Group"
        description="Get in touch with St Catherine's Group. We're here to answer your questions and discuss how we can support you.">
    <Navbar/>

    <section class="relative bg-linear-to-b from-white to-warm-50 py-20 md:py-28">
        <div class="max-w-4xl mx-auto px-6 text-center">
            <p class="text-green-dark text-sm font-medium tracking-[0.2em] uppercase mb-4">
                Get In Touch
            </p>
            <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-gray-900 mb-6">
                Contact Us
            </h1>
            <p class="text-gray-600 text-xl md:text-2xl leading-relaxed">
                We're here to listen, answer your questions, and discuss how we can best support you or your loved ones.
            </p>
        </div>
    </section>

    <section class="py-20 md:py-28 bg-white">
        <div class="max-w-5xl mx-auto px-6">
            <div class="space-y-12">
                <div>
                    <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-gray-900 mb-8 text-center">
                        Let's Talk
                    </h2>
                    <p class="text-gray-600 text-xl md:text-2xl lg:text-3xl leading-relaxed mb-12 text-center max-w-4xl mx-auto">
                        Whether you're looking for support for yourself or someone you care about, we're ready to help.
                    </p>
                </div>

                <div class="grid md:grid-cols-2 gap-10 max-w-4xl mx-auto">
                    <div class="flex items-start gap-6">
                        <div class="shrink-0 w-16 h-16 rounded-lg bg-green-dark/10 flex items-center justify-center">
                            <svg class="w-8 h-8 text-green-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                            </svg>
                        </div>
                        <div>
                            <h3 class="text-2xl md:text-3xl font-semibold text-gray-900 mb-2">Landline</h3>
                            <a href="tel:+442036633074"
                               class="text-xl md:text-2xl text-gray-600 hover:text-green-dark transition-colors">
                                020 3663 3074
                            </a>
                        </div>
                    </div>

                    <div class="flex items-start gap-6">
                        <div class="shrink-0 w-16 h-16 rounded-lg bg-green-dark/10 flex items-center justify-center">
                            <svg class="w-8 h-8 text-green-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/>
                            </svg>
                        </div>
                        <div>
                            <h3 class="text-2xl md:text-3xl font-semibold text-gray-900 mb-2">Mobile</h3>
                            <a href="tel:+447780149826"
                               class="text-xl md:text-2xl text-gray-600 hover:text-green-dark transition-colors">
                                07780 149826
                            </a>
                        </div>
                    </div>

                    <div class="flex items-start gap-6">
                        <div class="shrink-0 w-16 h-16 rounded-lg bg-green-dark/10 flex items-center justify-center">
                            <svg class="w-8 h-8 text-green-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                            </svg>
                        </div>
                        <div>
                            <h3 class="text-2xl md:text-3xl font-semibold text-gray-900 mb-2">Email</h3>
                            <a href="mailto:clientservices@stcatherinesgroup.com"
                               class="text-xl md:text-2xl text-gray-600 hover:text-green-dark transition-colors break-all">
                                clientservices@stcatherinesgroup.com
                            </a>
                        </div>
                    </div>

                    <div class="flex items-start gap-6">
                        <div class="shrink-0 w-16 h-16 rounded-lg bg-green-dark/10 flex items-center justify-center">
                            <svg class="w-8 h-8 text-green-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                            </svg>
                        </div>
                        <div>
                            <h3 class="text-2xl md:text-3xl font-semibold text-gray-900 mb-2">Address</h3>
                            <p class="text-xl md:text-2xl text-gray-600 leading-relaxed">
                                123 Healthcare Lane<br>
                                Your Town<br>
                                Postcode AB12 3CD
                            </p>
                        </div>
                    </div>
                </div>

                <div class="bg-warm-50 rounded-xl p-8 border-l-4 border-green-dark max-w-3xl mx-auto mt-12">
                    <p class="text-lg md:text-xl text-gray-700 leading-relaxed">
                        <strong class="text-gray-900 text-xl md:text-2xl">Need immediate support?</strong><br>
                        Our care services are available 24/7. Call us anytime on the number above.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <Footer/>
</Layout>
