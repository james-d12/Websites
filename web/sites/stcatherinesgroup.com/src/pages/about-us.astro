---
import {Image} from 'astro:assets';
import {getEntry, render} from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import CallToAction from '../components/CallToAction.astro';
import ProseContent from '../components/ProseContent.astro';

const entry = await getEntry('pages', 'about');
const {Content} = await render(entry);
const {title, description, hero} = entry.data;
---

<Layout title={title} description={description}>
    <Navbar/>
    <main>
        <section class="relative bg-warm-50 py-10">
            <div class="max-w-5xl mx-auto px-6 text-center">
                <p class="text-green-dark text-xl lg:text-3xl tracking-widest uppercase mb-4">
                    {hero.eyebrow}
                </p>
                <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-gray-900 mb-6">
                    {hero.heading}
                </h1>
            </div>
        </section>

        <section class="py-24 md:py-32 bg-white">
            <div class="max-w-6xl mx-auto px-6">
                <ProseContent>
                    <Content/>
                </ProseContent>
            </div>
        </section>

    </main>
    <CallToAction/>
    <Footer/>
</Layout>
