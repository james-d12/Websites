---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import CallToAction from '../components/CallToAction.astro';

// Example blog posts data
const featuredPost = {
    title: "Understanding the Benefits of One-to-One Care",
    excerpt: "Discover why personalized, one-to-one care can make all the difference in maintaining independence, dignity, and quality of life.",
    date: "14th March 2024",
    readTime: "5 min read",
    category: "Care Insights",
    image: "/api/placeholder/800/400"
};

const recentPosts = [
    {
        title: "5 Ways Companionship Improves Mental Wellbeing",
        excerpt: "Loneliness affects millions. Learn how regular companionship can transform mental health and overall quality of life.",
        date: "10th March 2024",
        readTime: "4 min read",
        category: "Wellbeing"
    },
    {
        title: "Supporting Someone with Dementia: A Family Guide",
        excerpt: "Practical advice and compassionate guidance for families navigating dementia care together.",
        date: "5th March 2024",
        readTime: "6 min read",
        category: "Dementia Care"
    },
    {
        title: "The Importance of Person-Centred Care",
        excerpt: "Why treating each individual as unique is at the heart of exceptional healthcare support.",
        date: "28th February 2024",
        readTime: "5 min read",
        category: "Care Philosophy"
    }
];
---

<Layout title="Blog - St Catherine's Group" description="Insights, advice, and stories about compassionate healthcare and one-to-one support.">
    <Navbar />

    <!-- Hero Section -->
    <section class="relative bg-gradient-to-b from-white to-warm-50 py-20 md:py-28">
        <div class="max-w-4xl mx-auto px-6 text-center">
            <p class="text-green-dark text-sm font-medium tracking-[0.2em] uppercase mb-4">
                Insights & Stories
            </p>
            <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-gray-900 mb-6">
                Our Blog
            </h1>
            <p class="text-gray-600 text-xl md:text-2xl leading-relaxed">
                Expert advice, compassionate insights, and stories from the world of person-centred care.
            </p>
        </div>
    </section>

    <!-- Featured Post -->
    <section class="py-20 md:py-28 bg-white">
        <div class="max-w-6xl mx-auto px-6">
            <div class="bg-warm-50 rounded-3xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
                <div class="grid lg:grid-cols-2 gap-0">
                    <div class="bg-gray-200 aspect-video lg:aspect-auto">
                        <div class="w-full h-full bg-gradient-to-br from-green-dark/20 to-green-dark/40 flex items-center justify-center">
                            <span class="text-white text-lg font-medium">Featured Image</span>
                        </div>
                    </div>
                    <div class="p-8 md:p-12 flex flex-col justify-center">
                        <div class="flex items-center gap-4 mb-4">
                            <span class="px-3 py-1 bg-green-dark text-white text-xs font-medium rounded-full uppercase tracking-wider">
                                Featured
                            </span>
                            <span class="text-sm text-gray-500">{featuredPost.category}</span>
                        </div>
                        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
                            {featuredPost.title}
                        </h2>
                        <p class="text-gray-600 text-lg leading-relaxed mb-6">
                            {featuredPost.excerpt}
                        </p>
                        <div class="flex items-center gap-4 text-sm text-gray-500 mb-6">
                            <span>{featuredPost.date}</span>
                            <span>•</span>
                            <span>{featuredPost.readTime}</span>
                        </div>
                        <a
                            href="/blog/understanding-benefits-one-to-one-care"
                            class="inline-flex items-center gap-2 text-green-dark font-semibold hover:gap-3 transition-all"
                        >
                            Read Full Article
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                            </svg>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Recent Posts -->
    <section class="py-20 md:py-28 bg-warm-50">
        <div class="max-w-6xl mx-auto px-6">
            <div class="mb-12">
                <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
                    Recent Articles
                </h2>
                <p class="text-gray-600 text-lg">
                    Explore our latest insights and advice
                </p>
            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
                {recentPosts.map(post => (
                    <article class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-all group">
                        <div class="aspect-video bg-gray-200">
                            <div class="w-full h-full bg-gradient-to-br from-green-dark/10 to-green-dark/20 flex items-center justify-center">
                                <span class="text-gray-500 text-sm">Article Image</span>
                            </div>
                        </div>
                        <div class="p-6">
                            <span class="text-xs text-green-dark font-medium uppercase tracking-wider">
                                {post.category}
                            </span>
                            <h3 class="text-xl font-bold text-gray-900 mt-3 mb-3 group-hover:text-green-dark transition-colors">
                                {post.title}
                            </h3>
                            <p class="text-gray-600 leading-relaxed mb-4">
                                {post.excerpt}
                            </p>
                            <div class="flex items-center gap-3 text-sm text-gray-500 mb-4">
                                <span>{post.date}</span>
                                <span>•</span>
                                <span>{post.readTime}</span>
                            </div>
                            <a
                                href="#"
                                class="inline-flex items-center gap-2 text-green-dark font-semibold text-sm hover:gap-3 transition-all"
                            >
                                Read More
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                </svg>
                            </a>
                        </div>
                    </article>
                ))}
            </div>
        </div>
    </section>

    <!-- Newsletter CTA -->
    <section class="py-20 md:py-28 bg-white">
        <div class="max-w-4xl mx-auto px-6 text-center">
            <div class="bg-gradient-to-br from-green-dark to-green-dark/90 rounded-3xl p-8 md:p-12 text-white">
                <h2 class="text-3xl md:text-4xl font-bold mb-4">
                    Stay Updated
                </h2>
                <p class="text-white/90 text-lg mb-8 max-w-2xl mx-auto">
                    Subscribe to our newsletter for regular insights, care tips, and updates from St Catherine's Group.
                </p>
                <form class="flex flex-col sm:flex-row gap-4 max-w-md mx-auto">
                    <input
                        type="email"
                        placeholder="Your email address"
                        class="flex-1 px-6 py-4 rounded-lg text-gray-900 focus:outline-none focus:ring-2 focus:ring-white"
                        required
                    />
                    <button
                        type="submit"
                        class="px-8 py-4 bg-white text-green-dark font-semibold rounded-lg hover:bg-gray-100 transition-colors"
                    >
                        Subscribe
                    </button>
                </form>
            </div>
        </div>
    </section>

    <CallToAction />
    <Footer />
</Layout>
