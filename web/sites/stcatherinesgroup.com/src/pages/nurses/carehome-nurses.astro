---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CallToAction from '../../components/CallToAction.astro';
import Hero from '../../components/Services/Hero.astro';
import Testimonials from '../../components/Services/Testimonials.astro';
import careHomeNursesImage from "../../assets/georg-arthur-pflueger-eO_JhqabBY0-unsplash.jpg";

const testimonials = [
    {
        quote: "The nursing support St Catherine's provides to our care home has raised our clinical standards significantly. Their expertise and professionalism are outstanding.",
        name: "Janet W.",
        relationship: "Care Home Manager",
        service: "Care Home Nursing"
    },
    {
        quote: "Having reliable specialist nurses we can call on for complex care needs gives us and our residents' families complete peace of mind. They're an extension of our team.",
        name: "David L.",
        relationship: "Care Home Director",
        service: "Care Home Nursing"
    },
    {
        quote: "The medication management support and training they provide has been invaluable. Our residents receive excellent clinical care thanks to their ongoing support.",
        name: "Mary T.",
        relationship: "Deputy Manager",
        service: "Care Home Nursing"
    }
];
---

<Layout title="Care Home Nurses - St Catherine's Group" description="Specialist nurses providing clinical support and healthcare services to care homes and residential facilities.">
    <Navbar />

    <Hero
        label="Specialist Nurses"
        title="Care Home Nurses"
        description="Specialist nursing support for care homes and residential facilities. Our experienced nurses provide clinical expertise, medication management, health monitoring, and specialist care to complement your care home team and ensure the highest standards of resident healthcare."
        image={careHomeNursesImage}
        imageAlt="Care home nursing services"
    />

    <!-- Services -->
    <section class="py-20 md:py-28 bg-white">
        <div class="max-w-6xl mx-auto px-6">
            <div class="text-center mb-16">
                <p class="text-green-dark text-sm font-medium tracking-[0.2em] uppercase mb-4">Care Home Support</p>
                <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
                    Clinical Excellence for Care Homes
                </h2>
                <p class="text-gray-600 text-lg leading-relaxed max-w-3xl mx-auto">
                    We provide registered nurses to support care homes with clinical care, resident monitoring, and specialist healthcare services.
                </p>
            </div>

            <div class="space-y-8">
                <div class="grid md:grid-cols-2 gap-8">
                    <div class="bg-warm-50 rounded-xl p-8">
                        <div class="flex items-start gap-4 mb-4">
                            <div class="w-12 h-12 rounded-lg bg-green-dark flex items-center justify-center flex-shrink-0">
                                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-xl font-bold text-gray-900 mb-3">Medication Management</h3>
                                <p class="text-gray-600 leading-relaxed mb-3">
                                    Comprehensive medication oversight including administration, stock management, audits, and ensuring compliance with care home medication policies.
                                </p>
                                <ul class="space-y-2 text-gray-600 text-sm">
                                    <li class="flex items-start gap-2">
                                        <span class="text-green-dark">→</span>
                                        <span>Medication rounds and administration</span>
                                    </li>
                                    <li class="flex items-start gap-2">
                                        <span class="text-green-dark">→</span>
                                        <span>MAR chart audits and compliance checks</span>
                                    </li>
                                    <li class="flex items-start gap-2">
                                        <span class="text-green-dark">→</span>
                                        <span>Controlled drug management</span>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div class="bg-warm-50 rounded-xl p-8">
                        <div class="flex items-start gap-4 mb-4">
                            <div class="w-12 h-12 rounded-lg bg-green-dark flex items-center justify-center flex-shrink-0">
                                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-xl font-bold text-gray-900 mb-3">Resident Health Monitoring</h3>
                                <p class="text-gray-600 leading-relaxed mb-3">
                                    Regular observation and monitoring of residents' health conditions, vital signs, and early identification of deterioration or health changes.
                                </p>
                                <ul class="space-y-2 text-gray-600 text-sm">
                                    <li class="flex items-start gap-2">
                                        <span class="text-green-dark">→</span>
                                        <span>Daily health assessments</span>
                                    </li>
                                    <li class="flex items-start gap-2">
                                        <span class="text-green-dark">→</span>
                                        <span>Vital signs monitoring</span>
                                    </li>
                                    <li class="flex items-start gap-2">
                                        <span class="text-green-dark">→</span>
                                        <span>Chronic condition management</span>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div class="bg-warm-50 rounded-xl p-8">
                        <div class="flex items-start gap-4 mb-4">
                            <div class="w-12 h-12 rounded-lg bg-green-dark flex items-center justify-center flex-shrink-0">
                                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-xl font-bold text-gray-900 mb-3">Clinical Procedures</h3>
                                <p class="text-gray-600 leading-relaxed mb-3">
                                    Specialist clinical procedures including wound care, catheter management, PEG feeding, and other nursing interventions requiring registered nurse expertise.
                                </p>
                                <ul class="space-y-2 text-gray-600 text-sm">
                                    <li class="flex items-start gap-2">
                                        <span class="text-green-dark">→</span>
                                        <span>Wound assessment and dressing</span>
                                    </li>
                                    <li class="flex items-start gap-2">
                                        <span class="text-green-dark">→</span>
                                        <span>Catheter and stoma care</span>
                                    </li>
                                    <li class="flex items-start gap-2">
                                        <span class="text-green-dark">→</span>
                                        <span>PEG feeding and nutrition support</span>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div class="bg-warm-50 rounded-xl p-8">
                        <div class="flex items-start gap-4 mb-4">
                            <div class="w-12 h-12 rounded-lg bg-green-dark flex items-center justify-center flex-shrink-0">
                                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-xl font-bold text-gray-900 mb-3">Staff Training & Support</h3>
                                <p class="text-gray-600 leading-relaxed mb-3">
                                    Clinical supervision, training, and mentorship for care home staff to enhance their skills and maintain high standards of care delivery.
                                </p>
                                <ul class="space-y-2 text-gray-600 text-sm">
                                    <li class="flex items-start gap-2">
                                        <span class="text-green-dark">→</span>
                                        <span>Care staff clinical training</span>
                                    </li>
                                    <li class="flex items-start gap-2">
                                        <span class="text-green-dark">→</span>
                                        <span>Medication competency assessments</span>
                                    </li>
                                    <li class="flex items-start gap-2">
                                        <span class="text-green-dark">→</span>
                                        <span>Clinical supervision and mentoring</span>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div class="bg-warm-50 rounded-xl p-8">
                        <div class="flex items-start gap-4 mb-4">
                            <div class="w-12 h-12 rounded-lg bg-green-dark flex items-center justify-center flex-shrink-0">
                                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-xl font-bold text-gray-900 mb-3">CQC Compliance Support</h3>
                                <p class="text-gray-600 leading-relaxed mb-3">
                                    Supporting care homes to meet CQC regulations with clinical audits, care plan reviews, and quality assurance processes.
                                </p>
                                <ul class="space-y-2 text-gray-600 text-sm">
                                    <li class="flex items-start gap-2">
                                        <span class="text-green-dark">→</span>
                                        <span>Clinical care plan audits</span>
                                    </li>
                                    <li class="flex items-start gap-2">
                                        <span class="text-green-dark">→</span>
                                        <span>Documentation compliance checks</span>
                                    </li>
                                    <li class="flex items-start gap-2">
                                        <span class="text-green-dark">→</span>
                                        <span>Quality improvement initiatives</span>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div class="bg-warm-50 rounded-xl p-8">
                        <div class="flex items-start gap-4 mb-4">
                            <div class="w-12 h-12 rounded-lg bg-green-dark flex items-center justify-center flex-shrink-0">
                                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-xl font-bold text-gray-900 mb-3">Flexible Cover</h3>
                                <p class="text-gray-600 leading-relaxed mb-3">
                                    Providing registered nurse cover for shifts, holidays, sickness, or to meet increased clinical demands in your care home.
                                </p>
                                <ul class="space-y-2 text-gray-600 text-sm">
                                    <li class="flex items-start gap-2">
                                        <span class="text-green-dark">→</span>
                                        <span>Day and night shift cover</span>
                                    </li>
                                    <li class="flex items-start gap-2">
                                        <span class="text-green-dark">→</span>
                                        <span>Emergency short-notice cover</span>
                                    </li>
                                    <li class="flex items-start gap-2">
                                        <span class="text-green-dark">→</span>
                                        <span>Regular scheduled support</span>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Our Care Home Nurses -->
    <section class="py-20 md:py-28 bg-warm-50">
        <div class="max-w-6xl mx-auto px-6">
            <div class="grid lg:grid-cols-2 gap-12 items-center">
                <div>
                    <p class="text-green-dark text-sm font-medium tracking-[0.2em] uppercase mb-4">Our Team</p>
                    <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
                        Care Home Nursing Specialists
                    </h2>
                    <div class="space-y-4 text-gray-700 leading-relaxed">
                        <p>
                            Our care home nurses have extensive experience working in residential and nursing care environments. They understand the unique challenges and regulatory requirements of care home settings and work seamlessly with existing care teams.
                        </p>
                        <p>
                            Each nurse brings expertise in elderly care, dementia support, medication management, and clinical procedures commonly required in care homes. They're skilled at working with residents with complex needs and building positive relationships with families.
                        </p>
                        <p>
                            We provide reliable, professional nursing support that enhances your care home's clinical capabilities while maintaining continuity and familiarity for residents.
                        </p>
                    </div>
                </div>

                <div class="bg-white rounded-2xl p-8 shadow-lg">
                    <h3 class="text-2xl font-bold text-gray-900 mb-6">Our Care Home Nurses Provide:</h3>
                    <div class="space-y-4">
                        <div class="flex items-start gap-3">
                            <div class="w-6 h-6 rounded-full bg-green-dark flex items-center justify-center flex-shrink-0 mt-1">
                                <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                                </svg>
                            </div>
                            <span class="text-gray-700"><strong>Care Home Experience</strong> - Deep understanding of residential care environments</span>
                        </div>
                        <div class="flex items-start gap-3">
                            <div class="w-6 h-6 rounded-full bg-green-dark flex items-center justify-center flex-shrink-0 mt-1">
                                <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                                </svg>
                            </div>
                            <span class="text-gray-700"><strong>CQC Knowledge</strong> - Expertise in regulatory compliance and standards</span>
                        </div>
                        <div class="flex items-start gap-3">
                            <div class="w-6 h-6 rounded-full bg-green-dark flex items-center justify-center flex-shrink-0 mt-1">
                                <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                                </svg>
                            </div>
                            <span class="text-gray-700"><strong>Team Integration</strong> - Ability to work seamlessly with care home staff</span>
                        </div>
                        <div class="flex items-start gap-3">
                            <div class="w-6 h-6 rounded-full bg-green-dark flex items-center justify-center flex-shrink-0 mt-1">
                                <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                                </svg>
                            </div>
                            <span class="text-gray-700"><strong>Medication Expertise</strong> - Specialist knowledge in care home medication management</span>
                        </div>
                        <div class="flex items-start gap-3">
                            <div class="w-6 h-6 rounded-full bg-green-dark flex items-center justify-center flex-shrink-0 mt-1">
                                <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                                </svg>
                            </div>
                            <span class="text-gray-700"><strong>Reliable & Professional</strong> - Consistent, high-quality clinical support</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <Testimonials testimonials={testimonials} />
    <CallToAction />
    <Footer />
</Layout>
