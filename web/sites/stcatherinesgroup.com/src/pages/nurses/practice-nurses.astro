---
import { getEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CallToAction from '../../components/CallToAction.astro';
import * as ServiceComponent from "../../components/Services";
import * as NurseComponent from "../../components/Nurses";
import practiceNursesImage from "../../assets/practice-nurses.jpg";

const entry = await getEntry('nurses', 'practice-nurses');
if (!entry) throw new Error('Nurses content not found: practice-nurses');
const { meta, hero, features, team, testimonials, testimonialsBackground, ctaBackground } = entry.data;
---

<Layout title={meta.title} description={meta.description}>
    <Navbar/>

    <main>
        <ServiceComponent.ServicesHero
                label={hero.label}
                title={hero.title}
                description={hero.description}
                image={practiceNursesImage}
                imageAlt={hero.imageAlt}
        />

        <NurseComponent.NursesFeatures
                eyebrow={features.eyebrow}
                title={features.title}
                description={features.description}
                cards={features.cards}
        />

        <NurseComponent.NursesTeam
                eyebrow={team.eyebrow}
                title={team.title}
                paragraphs={team.paragraphs}
                checklistTitle={team.checklistTitle}
                checklistItems={team.checklistItems}
        />

        <ServiceComponent.ServicesTestimonials testimonials={testimonials} background={testimonialsBackground}/>
    </main>

    <CallToAction background={ctaBackground}/>
    <Footer/>
</Layout>
